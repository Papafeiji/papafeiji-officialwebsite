---
import TutorialLayout from '../../layouts/TutorialLayout.astro';
---

<TutorialLayout title="联系我们" description="使用过程中需要帮助，或有任何需求和想法，可添加客服。">
  <section class="max-w-3xl mx-auto px-6 py-12 sm:py-16 lg:py-20 text-center">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight gradient-text mb-8">联系我们</h1>
    <p class="text-text-secondary text-lg mb-12">使用过程中需要帮助，或有任何需求和想法，可添加下方客服。</p>
    <img
      src="https://papafeiji.cn/about.png"
      alt="微信搜索公众号爬爬记忆助手"
      class="mx-auto max-w-full rounded-xl shadow-lg"
    />
  </section>
</TutorialLayout>
