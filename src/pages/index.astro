---
import Layout from '../layouts/Layout.astro';
import { createT } from '../i18n/translations';
import Hero from '../components/Hero.astro';
import Background from '../components/Background.astro';
import Solution from '../components/Solution.astro';
import Benefits from '../components/Benefits.astro';
import FeatureAI from '../components/FeatureAI.astro';
import FeatureLocation from '../components/FeatureLocation.astro';
import FeatureFamily from '../components/FeatureFamily.astro';
import FeatureMCP from '../components/FeatureMCP.astro';
import HowItWorks from '../components/HowItWorks.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';

const _ = createT('zh');
---

<Layout
  title={_('meta.title')}
  description={_('meta.desc')}
  lang="zh"
>
  <Hero lang="zh" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "爬爬记忆助手",
    "alternateName": "PathMemo",
    "url": "https://papafeiji.cn",
    "logo": "https://papafeiji.cn/papafeiji.png",
    "description": "家庭私密时光记录助手 - 开源的私密时光记录工具",
    "sameAs": ["https://github.com/Papafeiji/pathmemos"]
  })} />
  <Background lang="zh" />
  <Solution lang="zh" />
  <Benefits lang="zh" />
  <FeatureAI lang="zh" />
  <FeatureLocation lang="zh" />
  <FeatureFamily lang="zh" />
  <FeatureMCP lang="zh" />
  <HowItWorks lang="zh" />
  <OpenSource lang="zh" />
  <Footer lang="zh" />
</Layout>
