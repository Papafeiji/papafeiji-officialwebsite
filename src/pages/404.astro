---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found" lang="zh">
  <div class="min-h-[60vh] flex items-center justify-center text-center px-6">
    <div>
      <h1 class="text-6xl md:text-8xl font-bold text-brand-gold mb-4">404</h1>
      <p class="text-xl text-text-secondary mb-8">页面未找到 / Page not found</p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-gold text-contrast-btn-text font-semibold hover:bg-brand-warm transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        返回首页
      </a>
    </div>
  </div>
</Layout>
