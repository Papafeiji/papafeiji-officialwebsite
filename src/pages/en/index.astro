---
import Layout from '../../layouts/Layout.astro';
import { createT } from '../../i18n/translations';
import Hero from '../../components/Hero.astro';
import Background from '../../components/Background.astro';
import Solution from '../../components/Solution.astro';
import Benefits from '../../components/Benefits.astro';
import FeatureAI from '../../components/FeatureAI.astro';
import FeatureLocation from '../../components/FeatureLocation.astro';
import FeatureFamily from '../../components/FeatureFamily.astro';
import FeatureMCP from '../../components/FeatureMCP.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import OpenSource from '../../components/OpenSource.astro';
import Footer from '../../components/Footer.astro';

const _ = createT('en');
---

<Layout
  title={_('meta.title')}
  description={_('meta.desc')}
  lang="en"
>
  <Hero lang="en" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PathMemo",
    "alternateName": "爬爬记忆助手",
    "url": "https://papafeiji.cn",
    "logo": "https://papafeiji.cn/papafeiji.png",
    "description": "Private Family Memory Keeper - Open-source private time recording tool",
    "sameAs": ["https://github.com/Papafeiji/pathmemos"]
  })} />
  <Background lang="en" />
  <Solution lang="en" />
  <Benefits lang="en" />
  <FeatureAI lang="en" />
  <FeatureLocation lang="en" />
  <FeatureFamily lang="en" />
  <FeatureMCP lang="en" />
  <HowItWorks lang="en" />
  <OpenSource lang="en" />
  <Footer lang="en" />
</Layout>
