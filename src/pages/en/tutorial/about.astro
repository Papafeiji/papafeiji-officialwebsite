---
import TutorialLayout from '../../../layouts/TutorialLayout.astro';
---

<TutorialLayout lang="en" title="Contact Us" description="Need help or have any questions? Contact us below.">
  <section class="max-w-3xl mx-auto px-6 py-12 sm:py-16 lg:py-20 text-center">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight gradient-text mb-8">Contact Us</h1>
    <p class="text-text-secondary text-lg mb-12">Need help using PathMemo, or have any questions or ideas? Add our customer service below.</p>
    <img
      src="https://papafeiji.cn/about.png"
      alt="WeChat public account: PathMemo"
      class="mx-auto max-w-full rounded-xl shadow-lg"
    />
  </section>
</TutorialLayout>
