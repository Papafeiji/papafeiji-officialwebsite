---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = 'zh' } = Astro.props;
---

<Layout title={title} description={description} lang={lang} ogType="article">
  <slot />
  <Footer lang={lang} />
</Layout>
