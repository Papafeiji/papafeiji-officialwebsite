---
import ScrollReveal from './ScrollReveal.tsx';
---
<section class="relative py-32 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_50%,rgba(181,141,94,0.08),transparent)]"></div>

  <div class="relative max-w-5xl mx-auto">
    <ScrollReveal client:visible>
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/[0.03] border border-white/[0.06] mb-10">
          <span class="text-sm text-brand-gold font-medium">解决方案</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6 leading-tight">
          跨 AI 的<span class="gradient-text">外挂记忆库</span>
        </h2>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
          用一个独立、持久、可共享的记忆层，为所有大模型 App 统一提供真实世界的上下文。
          让你的龙虾，长出脚，来到真实世界。
        </p>
      </div>
    </ScrollReveal>

    <!-- Architecture diagram -->
    <ScrollReveal client:visible delay={200}>
      <div class="relative p-8 md:p-12 rounded-3xl bg-bg-card border border-border-subtle overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>

        <div class="grid md:grid-cols-3 gap-8 items-center">
          <!-- Left: AI Apps -->
          <div class="space-y-4">
            <p class="text-sm text-text-muted text-center mb-4 font-medium">各大模型 App</p>
            <div class="space-y-3">
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <div class="w-8 h-8 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400 text-xs font-bold">豆</div>
                <span class="text-sm text-text-secondary">豆包</span>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <div class="w-8 h-8 rounded-lg bg-emerald-500/20 flex items-center justify-center text-emerald-400 text-xs font-bold">K</div>
                <span class="text-sm text-text-secondary">Kimi</span>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <div class="w-8 h-8 rounded-lg bg-purple-500/20 flex items-center justify-center text-purple-400 text-xs font-bold">千</div>
                <span class="text-sm text-text-secondary">通义千问</span>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <div class="w-8 h-8 rounded-lg bg-orange-500/20 flex items-center justify-center text-orange-400 text-xs font-bold">G</div>
                <span class="text-sm text-text-secondary">ChatGPT</span>
              </div>
            </div>
          </div>

          <!-- Center: Memory Hub -->
          <div class="relative flex flex-col items-center justify-center">
            <div class="absolute inset-0 bg-brand-gold/5 rounded-2xl blur-xl"></div>
            <div class="relative p-6 rounded-2xl bg-gradient-to-b from-brand-gold/10 to-brand-gold/5 border border-brand-gold/20 text-center">
              <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-brand-gold/20 flex items-center justify-center">
                <img src="/papafeiji.png" alt="爬爬记忆助手" class="w-10 h-10 rounded-lg" />
              </div>
              <h3 class="text-lg font-bold text-brand-warm mb-1">爬爬记忆助手</h3>
              <p class="text-xs text-brand-gold">统一记忆中枢</p>
              <div class="mt-4 pt-4 border-t border-white/[0.06] space-y-2">
                <div class="text-xs text-text-secondary">MCP 协议</div>
                <div class="text-xs text-text-secondary">API Key 接入</div>
                <div class="text-xs text-text-secondary">自动轨迹同步</div>
              </div>
            </div>
            <!-- Arrows -->
            <div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2 -translate-x-full">
              <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><path d="M0 12h32" stroke="rgba(181,141,94,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/><path d="M28 6l6 6-6 6" stroke="rgba(181,141,94,0.4)" stroke-width="1.5"/></svg>
            </div>
            <div class="hidden md:block absolute right-0 top-1/2 -translate-y-1/2 translate-x-full">
              <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><path d="M8 12h32" stroke="rgba(181,141,94,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/><path d="M32 6l6 6-6 6" stroke="rgba(181,141,94,0.4)" stroke-width="1.5"/></svg>
            </div>
          </div>

          <!-- Right: Data Sources -->
          <div class="space-y-4">
            <p class="text-sm text-text-muted text-center mb-4 font-medium">记忆数据来源</p>
            <div class="space-y-3">
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span class="text-sm text-text-secondary">地理位置轨迹</span>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
                <span class="text-sm text-text-secondary">日记与备忘</span>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span class="text-sm text-text-secondary">家庭共享记忆</span>
              </div>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/[0.06]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                <span class="text-sm text-text-secondary">照片与文件</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
