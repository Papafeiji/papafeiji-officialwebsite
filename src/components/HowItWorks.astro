---
import { t } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = (key: any) => t(lang, key as any);

const steps = [
  {
    num: "01",
    title: 'how.step1.title',
    desc: 'how.step1.desc',
    cmd: "curl -fsSL https://papafeiji.cn/install.sh | bash"
  },
  {
    num: "02",
    title: 'how.step2.title',
    desc: 'how.step2.desc',
    cmd: null
  },
  {
    num: "03",
    title: 'how.step3.title',
    desc: 'how.step3.desc',
    cmd: null
  }
];
---

<section id="how-it-works" class="relative py-32 px-6">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_50%_50%,rgba(181,141,94,0.06),transparent)]"></div>

  <div class="relative max-w-5xl mx-auto">
    
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
          <span class="text-sm text-brand-gold font-medium">{_('how.badge')}</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
          {_('how.title.1')}<span class="gradient-text">{_('how.title.2')}</span>
        </h2>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          {_('how.subtitle')}
        </p>
      </div>
    

    <div class="space-y-8">
      {steps.map((step, i) => (
        
          <div class="flex flex-col md:flex-row gap-8 items-start p-8 rounded-2xl bg-bg-card border border-border-subtle">
            <div class="flex-shrink-0">
              <span class="text-5xl font-bold text-brand-gold/20">{step.num}</span>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-semibold text-text-primary mb-3">{_(step.title)}</h3>
              <p class="text-text-secondary leading-relaxed mb-4">{_(step.desc)}</p>
              {step.cmd && (
                <div class="code-block">
                  <div class="code-header">
                    <span class="code-dot"></span>
                    <span class="code-dot"></span>
                    <span class="code-dot"></span>
                    <span class="ml-2 text-xs text-text-muted">Terminal</span>
                  </div>
                  <div class="code-body">
                    <span class="prompt">$</span> <span class="cmd">{step.cmd}</span>
                  </div>
                </div>
              )}
            </div>
          </div>
        
      ))}
    </div>
  </div>
</section>
