---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="location" class="relative py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('location.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('location.title.1')}<span class="gradient-text">{_('location.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('location.subtitle')}</p>
    </div>

    <!-- Map trajectory illustration (desktop only) -->
    <div class="hidden md:block relative mb-20 overflow-hidden rounded-3xl bg-bg-card border border-surface-06">
      <div class="absolute inset-0">
        <!-- Map grid -->
        <svg class="w-full h-full opacity-[0.06]" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="map-grid" width="60" height="60" patternUnits="userSpaceOnUse">
              <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" class="text-brand-gold"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#map-grid)"/>
          <!-- Roads -->
          <path d="M0 180 Q200 170 400 190 Q600 210 720 175" fill="none" stroke="rgba(181,141,94,0.12)" stroke-width="2"/>
          <path d="M0 280 Q250 260 500 290 Q650 310 720 265" fill="none" stroke="rgba(181,141,94,0.08)" stroke-width="1.5"/>
          <path d="M180 400 Q350 100 520 400" fill="none" stroke="rgba(181,141,94,0.1)" stroke-width="2"/>
          <path d="M300 0 Q280 200 320 400" fill="none" stroke="rgba(181,141,94,0.08)" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="relative h-72 md:h-80">
        <!-- Trajectory path -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 720 320" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="trail-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(181,141,94,0.1)"/>
              <stop offset="50%" stop-color="rgba(181,141,94,0.5)"/>
              <stop offset="100%" stop-color="rgba(181,141,94,0.8)"/>
            </linearGradient>
            <linearGradient id="trail-grad-2" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(59,130,246,0.1)"/>
              <stop offset="50%" stop-color="rgba(59,130,246,0.4)"/>
              <stop offset="100%" stop-color="rgba(59,130,246,0.7)"/>
            </linearGradient>
          </defs>
          <!-- Path line -->
          <path d="M80 220 Q140 160 200 210 Q260 260 320 180 Q380 100 430 150 Q480 200 530 120 Q580 40 630 90"
                fill="none" stroke="url(#trail-grad)" stroke-width="2.5" stroke-dasharray="8 4"
                class="trajectory-line"/>
          <path d="M630 90 Q660 120 680 60"
                fill="none" stroke="url(#trail-grad-2)" stroke-width="2.5" stroke-dasharray="4 4"
                style="animation: dashMove 1.5s linear infinite;"/>
        </svg>

        <!-- GPS pins -->
        <div class="absolute z-10" style="left:9%;top:57%;animation: pinAppear1 4s ease-out infinite;">
          <div class="relative flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-brand-gold shadow-lg shadow-brand-gold/50"></div>
            <div class="w-1.5 h-1.5 mt-0.5 rounded-full bg-brand-gold/40"></div>
          </div>
        </div>
        <div class="absolute z-10" style="left:26%;top:53%;animation: pinAppear2 4s ease-out infinite;">
          <div class="relative flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-brand-gold shadow-lg shadow-brand-gold/50"></div>
            <div class="w-1.5 h-1.5 mt-0.5 rounded-full bg-brand-gold/40"></div>
          </div>
        </div>
        <div class="absolute z-10" style="left:42%;top:44%;animation: pinAppear3 4s ease-out infinite;">
          <div class="relative flex flex-col items-center">
            <div class="w-4 h-4 rounded-full bg-brand-gold shadow-lg shadow-brand-gold/60"></div>
            <div class="w-2 h-2 mt-0.5 rounded-full bg-brand-gold/50"></div>
          </div>
        </div>
        <div class="absolute z-10" style="left:58%;top:35%;animation: pinAppear4 4s ease-out infinite;">
          <div class="relative flex flex-col items-center">
            <div class="w-4 h-4 rounded-full bg-brand-gold shadow-lg shadow-brand-gold/60"></div>
            <div class="w-2 h-2 mt-0.5 rounded-full bg-brand-gold/50"></div>
          </div>
        </div>
        <div class="absolute z-10" style="left:72%;top:25%;animation: pinAppear5 4s ease-out infinite;">
          <div class="relative">
            <div class="w-5 h-5 rounded-full bg-blue-500 shadow-lg shadow-blue-500/60 animate-pulse"></div>
            <div class="absolute inset-0 w-5 h-5 rounded-full bg-blue-500/40 animate-ping"></div>
            <div class="w-2.5 h-2.5 mt-1 mx-auto rounded-full bg-blue-400/50"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Smart Stay Detection' : '智能停留识别'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Background GPS collection without user intervention. Intelligently identifies valid stay behavior and filters out irrelevant movement tracks.' : '后台无感采集 GPS 点位，智能判定有效停留行为，过滤无效移动轨迹。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><path d="M6 6h.01"/><path d="M6 18h.01"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'AI Trajectory Clustering' : 'AI 轨迹聚合'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Auto-clusters spatiotemporal trajectories, resolves real-world addresses, matches frequent locations. Smart deduplication keeps your diary clean and organized.' : '自动聚类时空轨迹、解析真实地址、匹配常用地点，智能去重，保证日记干净整洁。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Smart Status Alerts' : '智能状态提醒'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Intelligent alerts for abnormal silence and new location arrivals, balancing recording completeness with user experience.' : '异常静默、新地点抵达智能提醒，兼顾记录完整性与用户体验。'}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes dashMove {
    to { stroke-dashoffset: -16; }
  }
  @keyframes pinAppear1 {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    15%, 85% { opacity: 1; transform: scale(1); }
  }
  @keyframes pinAppear2 {
    0%, 20% { opacity: 0.3; transform: scale(0.8); }
    30%, 85% { opacity: 1; transform: scale(1); }
    100% { opacity: 0.3; }
  }
  @keyframes pinAppear3 {
    0%, 40% { opacity: 0.3; transform: scale(0.8); }
    50%, 85% { opacity: 1; transform: scale(1); }
    100% { opacity: 0.3; }
  }
  @keyframes pinAppear4 {
    0%, 60% { opacity: 0.3; transform: scale(0.8); }
    70%, 85% { opacity: 1; transform: scale(1); }
    100% { opacity: 0.3; }
  }
  @keyframes pinAppear5 {
    0%, 80% { opacity: 0.4; transform: scale(0.9); }
    85%, 100% { opacity: 1; transform: scale(1); }
  }
  .trajectory-line {
    stroke-dasharray: 8 4;
    animation: drawPath 4s ease-in-out infinite alternate;
  }
  @keyframes drawPath {
    0% { stroke-dashoffset: 600; opacity: 0.3; }
    50% { opacity: 0.8; }
    100% { stroke-dashoffset: 0; opacity: 1; }
  }
</style>
