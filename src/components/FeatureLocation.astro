---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="location" class="relative py-32 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('location.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('location.title.1')}<span class="gradient-text">{_('location.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('location.subtitle')}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Smart Stay Detection' : '智能停留识别'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Background GPS collection without user intervention. Intelligently identifies valid stay behavior and filters out irrelevant movement tracks.' : '后台无感采集 GPS 点位，智能判定有效停留行为，过滤无效移动轨迹。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><path d="M6 6h.01"/><path d="M6 18h.01"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'AI Trajectory Clustering' : 'AI 轨迹聚合'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Auto-clusters spatiotemporal trajectories, resolves real-world addresses, matches frequent locations. Smart deduplication keeps your diary clean and organized.' : '自动聚类时空轨迹、解析真实地址、匹配常用地点，智能去重，保证日记干净整洁。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Smart Status Alerts' : '智能状态提醒'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Intelligent alerts for abnormal silence and new location arrivals, balancing recording completeness with user experience.' : '异常静默、新地点抵达智能提醒，兼顾记录完整性与用户体验。'}
        </p>
      </div>
    </div>
  </div>
</section>
