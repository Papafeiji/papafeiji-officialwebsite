---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';

const pins = [
  { left: 8, top: 72, delay: 0 },
  { left: 18, top: 58, delay: 0.2 },
  { left: 28, top: 68, delay: 0.4 },
  { left: 38, top: 48, delay: 0.6 },
  { left: 48, top: 62, delay: 0.8 },
  { left: 56, top: 38, delay: 1.0 },
  { left: 66, top: 52, delay: 1.2 },
  { left: 74, top: 32, delay: 1.4 },
  { left: 84, top: 46, delay: 1.6 },
  { left: 92, top: 28, delay: 1.8 },
];
---
<section id="location" class="relative py-16 md:py-24 px-6 overflow-hidden" data-reveal>
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10 md:mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-6">
        <span class="text-sm text-brand-gold font-medium">{_('location.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('location.title.1')}<span class="gradient-text">{_('location.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('location.subtitle')}</p>
    </div>

    <!-- City trajectory illustration -->
    <div class="relative mb-14 md:mb-16 overflow-hidden rounded-3xl bg-bg-card border border-surface-06 h-72 md:h-96">
      <!-- Map background -->
      <img
        src="/map-1024.webp"
        srcset="/map-720.webp 720w, /map-1024.webp 1024w, /map-1440.webp 1440w"
        sizes="(max-width: 768px) 100vw, 1024px"
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-bg-deep/30 via-transparent to-bg-deep/60"></div>

      <!-- Trajectory line -->
      <svg class="absolute inset-0 w-full h-full" viewBox="0 0 720 320" preserveAspectRatio="none">
        <defs>
          <linearGradient id="city-trail" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(181,141,94,0.3)"/>
            <stop offset="50%" stop-color="rgba(181,141,94,0.7)"/>
            <stop offset="100%" stop-color="rgba(181,141,94,1)"/>
          </linearGradient>
        </defs>
        <path
          d="M40 240 Q100 210 160 230 Q220 250 280 200 Q340 150 400 180 Q460 210 520 160 Q580 110 640 130 Q700 150 760 80"
          fill="none"
          stroke="url(#city-trail)"
          stroke-width="3"
          stroke-linecap="round"
          stroke-dasharray="8 6"
          style="animation: cityTrail 2.5s linear infinite"
        />
      </svg>

      <!-- Location pins -->
      {pins.map((pin) => (
        <div
          class="absolute z-10 w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-brand-gold shadow-lg shadow-brand-gold/60 city-pin"
          style={`left:${pin.left}%;top:${pin.top}%;animation-delay:${pin.delay}s`}
        ></div>
      ))}
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Smart Stay Detection' : '智能停留识别'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Background GPS collection without user intervention. Intelligently identifies valid stay behavior and filters out irrelevant movement tracks.' : '后台持续采集 GPS 数据，智能识别有效停留行为，过滤无效移动轨迹。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><path d="M6 6h.01"/><path d="M6 18h.01"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'AI Trajectory Clustering' : 'AI 轨迹聚合'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Auto-clusters spatiotemporal trajectories, resolves real-world addresses, matches frequent locations. Smart deduplication keeps your diary clean and organized.' : '自动聚类时空轨迹，解析真实地址并匹配常用地点，生成结构化生活记录。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Smart Status Alerts' : '智能状态提醒'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Intelligent alerts for abnormal silence and new location arrivals, balancing recording completeness with user experience.' : '针对异常静默与新地点抵达提供智能提醒，平衡记录完整性与使用体验。'}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes cityTrail {
    to { stroke-dashoffset: -28; }
  }

  @keyframes pinPop {
    0%, 100% { transform: scale(0.7); opacity: 0.5; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  .city-pin {
    animation: pinPop 2.2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .city-pin, [style*="animation: cityTrail"] {
      animation: none !important;
    }
  }
</style>
