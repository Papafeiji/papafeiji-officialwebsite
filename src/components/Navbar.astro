---
import { createT } from '../i18n/translations';

export interface Props {
  lang?: string;
}
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
const home = isEn ? '/en/' : '/';
const otherLang = isEn ? 'zh' : 'en';
const otherLangUrl = isEn ? '/' : '/en/';
const siteName = _('site.name');
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-surface-06 bg-nav-bg backdrop-blur-xl">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={home} class="flex items-center gap-3 text-text-primary no-underline">
      <img src="/papafeiji-32.webp" srcset="/papafeiji-32.webp 1x, /papafeiji-128.webp 2x" alt={siteName} width="32" height="32" class="w-8 h-8 rounded-lg" decoding="async" />
      <span class="font-bold text-lg tracking-tight">{siteName}</span>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-2">
      <button class="theme-toggle" aria-pressed="true" aria-label="Switch to light theme">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a href={otherLangUrl} onclick={"localStorage.setItem('lang','"+otherLang+"')"} class="px-3 py-2 rounded-lg text-xs text-text-secondary hover:text-text-primary bg-surface-04 border border-surface-06 transition-all">{lang === 'en' ? '中文' : 'EN'}</a>
      <a href="https://github.com/Papafeiji/pathmemos" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-surface-04 border border-surface-06 text-sm text-text-secondary hover:text-text-primary hover:bg-surface-08 transition-all">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <!-- Mobile: toggle menu -->
    <div class="md:hidden relative" data-mobile-menu>
      <button id="mobile-menu-btn" class="flex items-center justify-center w-10 h-10 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-04 transition-all cursor-pointer select-none bg-transparent border-none" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="pointer-events:none"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <div id="mobile-menu" class="absolute right-0 top-16 w-64 bg-bg-card border border-surface-06 rounded-xl shadow-lg mx-4 p-4 flex-col gap-3 hidden opacity-0 scale-95 transition-all duration-200" role="menu">
        <div class="flex flex-col gap-3 px-4 py-2">
          <div class="flex items-center justify-between">
            <span class="text-sm text-text-secondary">{_('nav.theme')}</span>
            <button class="theme-toggle" aria-pressed="true" aria-label="Switch to light theme">
              <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <a href={otherLangUrl} onclick={"localStorage.setItem('lang','"+otherLang+"')"} class="flex items-center justify-center gap-2 px-3 py-2.5 rounded-lg text-sm text-text-secondary hover:text-text-primary bg-surface-04 border border-surface-06 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              {lang === 'en' ? '中文' : 'EN'}
            </a>
            <a href="https://github.com/Papafeiji/pathmemos" target="_blank" rel="noopener" class="flex items-center justify-center gap-2 px-3 py-2.5 rounded-lg text-sm text-text-secondary hover:text-text-primary bg-surface-04 border border-surface-06 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              {_('nav.github')}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script src="/scripts/navbar.js" defer></script>
<script src="/scripts/theme-toggle.js" defer></script>
