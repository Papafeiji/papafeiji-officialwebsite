---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="ai" class="relative py-16 md:py-24 px-6 overflow-hidden" data-reveal>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_50%,rgba(181,141,94,0.06),transparent)]"></div>
  <div class="relative max-w-5xl mx-auto">
    <div class="text-center mb-12 md:mb-14">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-6">
        <span class="text-sm text-brand-gold font-medium">{_('ai.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('ai.title.1')}<span class="gradient-text">{_('ai.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('ai.subtitle')}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><rect width="20" height="14" x="2" y="5" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary">{isEn ? 'Mini Program Chat' : '小程序端对话'}</h3>
        </div>
        <ul class="space-y-3 text-text-secondary text-sm leading-relaxed">
          {isEn ? <>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Real-time Q&A based on last 90 days of personal and family memories</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Streaming output for an immersive AI chat experience</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Smart date and location linking — one tap to jump to the original diary</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Supports life review, trajectory queries, and content summaries</li>
          </> : <>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 问"去年夏天去了哪"，它真的答得出来</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 流式回复，像真人聊天一样自然</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 提到日期、地点自动关联原始日记</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 生活复盘、轨迹查询、内容总结，一句话搞定</li>
          </>}
        </ul>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-text-primary">{isEn ? 'Official Account Voice Notes' : '服务号语音速记'}</h3>
        </div>
        <ul class="space-y-3 text-text-secondary text-sm leading-relaxed">
          {isEn ? <>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Quick text/voice interaction directly within WeChat</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Auto voice recognition with smart AI replies</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Dual-channel data and quota fully shared between Mini Program and Official Account</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> Perfect for fragmented moments — quick recording and memory review on the go</li>
          </> : <>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 微信里直接语音/文字，不用切 App</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 语音自动识别，AI 即时回复</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 小程序和服务号数据、额度完全互通</li>
            <li class="flex gap-2"><span class="text-brand-gold mt-1 shrink-0">&#9679;</span> 地铁上、睡前、排队时，随手记随手问</li>
          </>}
        </ul>
      </div>
    </div>
  </div>
</section>
