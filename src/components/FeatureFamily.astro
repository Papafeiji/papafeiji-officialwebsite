---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="family" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('family.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('family.title.1')}<span class="gradient-text">{_('family.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('family.subtitle')}</p>
    </div>

    <div class="space-y-10 mb-20">

      <!-- A: Timeline -->
      <div>
        <p class="text-sm text-brand-gold font-medium mb-4 text-center">A. 家庭时光轴</p>
        <div class="overflow-hidden rounded-3xl bg-bg-card border border-surface-06 p-6 md:p-10">
          <div class="relative overflow-x-auto pb-4">
            <div class="flex gap-6 md:gap-10 items-start min-w-max" style="padding-left:2rem;padding-right:2rem">
              {['妈妈','爸爸','宝宝','爷爷','奶奶','全家'].map((name,i) => (
                <div class="flex flex-col items-center gap-3 shrink-0" style={`animation: fadeInUp 0.5s ease-out ${i*0.15}s both`}>
                  <div class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-brand-gold/15 border-2 border-brand-gold/25 flex items-center justify-center text-brand-gold text-lg font-bold shadow-md"
                       style={i===5 ? 'background:rgba(181,141,94,0.25);border-color:rgba(181,141,94,0.5)' : ''}>{name[0]}</div>
                  <span class="text-[10px] md:text-xs text-text-muted">{name}</span>
                  <div class="w-32 md:w-40 h-20 md:h-24 rounded-xl bg-surface-03 border border-surface-06 p-2 md:p-3 flex flex-col justify-between">
                    <div class="text-[9px] md:text-[10px] text-text-secondary leading-tight">{isEn ? 'Traveled to the park today, had a great time together' : '今天去了公园散步，一起度过了美好时光'}</div>
                    <div class="text-[8px] md:text-[9px] text-text-muted">{isEn ? 'Jul 18' : '7月18日'}</div>
                  </div>
                  {i < 5 && (<div class="w-px h-4 bg-brand-gold/20"></div>)}
                </div>
              ))}
            </div>
            <!-- Timeline line -->
            <div class="absolute bottom-4 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-gold/30 to-transparent"></div>
          </div>
        </div>
      </div>

      <!-- B: Collage Wall -->
      <div>
        <p class="text-sm text-brand-gold font-medium mb-4 text-center">B. 拼接墙</p>
        <div class="overflow-hidden rounded-3xl bg-bg-card border border-surface-06 p-6 md:p-10">
          <div class="relative h-60 md:h-72">
            <!-- Center: merged family -->
            <div class="absolute z-10 flex flex-col items-center" style="left:50%;top:50%;transform:translate(-50%,-50%)">
              <div class="w-28 h-28 md:w-36 md:h-36 rounded-2xl bg-brand-gold/10 border-2 border-brand-gold/25 flex items-center justify-center shadow-lg shadow-brand-gold/15" style="animation: pulse 3s ease-in-out infinite">
                <div class="text-center">
                  <div class="text-brand-gold font-bold text-sm md:text-base">{isEn ? 'Family' : '全家共享'}</div>
                  <div class="text-text-muted text-[9px] md:text-[10px] mt-1">{isEn ? '12 entries today' : '今日 12 篇日记'}</div>
                </div>
              </div>
            </div>
            <!-- Scattered individual cards flying in -->
            <div class="absolute" style="left:8%;top:15%;transform:rotate(-8deg);animation:floatIn 3s ease-out both">
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-xl bg-purple-500/6 border border-purple-500/15 flex flex-col items-center justify-center gap-1 shadow-sm">
                <div class="w-7 h-7 rounded-full bg-purple-500/15 flex items-center justify-center text-purple-400 text-[10px] font-bold">妈</div>
                <span class="text-[8px] text-text-muted">3 篇</span>
              </div>
            </div>
            <div class="absolute" style="right:8%;top:12%;transform:rotate(5deg);animation:floatIn 3.5s ease-out 0.2s both">
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-xl bg-orange-500/6 border border-orange-500/15 flex flex-col items-center justify-center gap-1 shadow-sm">
                <div class="w-7 h-7 rounded-full bg-orange-500/15 flex items-center justify-center text-orange-400 text-[10px] font-bold">爸</div>
                <span class="text-[8px] text-text-muted">4 篇</span>
              </div>
            </div>
            <div class="absolute" style="left:5%;bottom:20%;transform:rotate(-12deg);animation:floatIn 3.8s ease-out 0.4s both">
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-xl bg-cyan-500/6 border border-cyan-500/15 flex flex-col items-center justify-center gap-1 shadow-sm">
                <div class="w-7 h-7 rounded-full bg-cyan-500/15 flex items-center justify-center text-cyan-400 text-[10px] font-bold">宝</div>
                <span class="text-[8px] text-text-muted">2 篇</span>
              </div>
            </div>
            <div class="absolute" style="right:5%;bottom:18%;transform:rotate(9deg);animation:floatIn 4s ease-out 0.6s both">
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-xl bg-emerald-500/6 border border-emerald-500/15 flex flex-col items-center justify-center gap-1 shadow-sm">
                <div class="w-7 h-7 rounded-full bg-emerald-500/15 flex items-center justify-center text-emerald-400 text-[10px] font-bold">爷</div>
                <span class="text-[8px] text-text-muted">3 篇</span>
              </div>
            </div>
            <!-- Flow lines to center -->
            <svg class="absolute inset-0 w-full h-full z-0" viewBox="0 0 720 270" preserveAspectRatio="none">
              <g opacity="0.2" stroke-dasharray="4 5">
                <line x1="100" y1="80" x2="360" y2="135" stroke="#8B5CF6" stroke-width="1.5"><animate attributeName="stroke-dashoffset" from="0" to="-18" dur="2s" repeatCount="indefinite"/></line>
                <line x1="620" y1="75" x2="360" y2="135" stroke="#D97706" stroke-width="1.5"><animate attributeName="stroke-dashoffset" from="0" to="-18" dur="2.3s" repeatCount="indefinite"/></line>
                <line x1="80" y1="200" x2="360" y2="145" stroke="#06B6D4" stroke-width="1.5"><animate attributeName="stroke-dashoffset" from="0" to="-18" dur="2.6s" repeatCount="indefinite"/></line>
                <line x1="640" y1="195" x2="360" y2="145" stroke="#10B981" stroke-width="1.5"><animate attributeName="stroke-dashoffset" from="0" to="-18" dur="2.9s" repeatCount="indefinite"/></line>
              </g>
            </svg>
            <style>
              @keyframes floatIn { from{opacity:0;transform:translate(0,30px) rotate(0)} to{opacity:1} }
              @keyframes pulse { 0%,100%{opacity:0.8} 50%{opacity:1} }
            </style>
          </div>
        </div>
      </div>

      <!-- C: Concentric Merge -->
      <div>
        <p class="text-sm text-brand-gold font-medium mb-4 text-center">C. 同心圆合并</p>
        <div class="overflow-hidden rounded-3xl bg-bg-card border border-surface-06 p-6 md:p-10">
          <div class="relative h-60 md:h-72 flex items-center justify-center">
            <!-- Phase 1: scattered rings -->
            <div class="absolute" style="left:15%;top:25%">
              <div class="w-14 h-14 rounded-full bg-purple-500/8 border-2 border-purple-500/25 flex items-center justify-center text-purple-400 text-sm font-bold" style="animation: ringFade 4s ease-in-out infinite">妈</div>
            </div>
            <div class="absolute" style="right:15%;top:25%">
              <div class="w-14 h-14 rounded-full bg-orange-500/8 border-2 border-orange-500/25 flex items-center justify-center text-orange-400 text-sm font-bold" style="animation: ringFade 4s ease-in-out infinite 0.4s">爸</div>
            </div>
            <div class="absolute" style="left:25%;bottom:22%">
              <div class="w-12 h-12 rounded-full bg-cyan-500/8 border-2 border-cyan-500/25 flex items-center justify-center text-cyan-400 text-xs font-bold" style="animation: ringFade 4s ease-in-out infinite 0.8s">宝</div>
            </div>
            <div class="absolute" style="right:25%;bottom:22%">
              <div class="w-12 h-12 rounded-full bg-emerald-500/8 border-2 border-emerald-500/25 flex items-center justify-center text-emerald-400 text-xs font-bold" style="animation: ringFade 4s ease-in-out infinite 1.2s">爷</div>
            </div>
            <!-- Center: merged ring (larger, gold) -->
            <div class="absolute z-10" style="left:50%;top:50%;transform:translate(-50%,-50%)">
              <div class="w-24 h-24 md:w-28 md:h-28 rounded-full bg-brand-gold/10 border-3 border-brand-gold/30 flex items-center justify-center shadow-lg shadow-brand-gold/15">
                <div class="text-center">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  <div class="text-brand-gold text-[10px] md:text-xs mt-1 font-bold">{isEn ? 'SHARED' : '共享'}</div>
                </div>
              </div>
            </div>
            <!-- Connecting arcs -->
            <svg class="absolute inset-0 w-full h-full z-0" viewBox="0 0 720 270" preserveAspectRatio="none">
              <defs>
                <radialGradient id="c-grad"><stop offset="50%" stop-color="rgba(181,141,94,0.08)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
              </defs>
              <circle cx="360" cy="135" r="120" fill="none" stroke="rgba(181,141,94,0.15)" stroke-width="1.5" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="3s" repeatCount="indefinite"/></circle>
              <circle cx="360" cy="135" r="80" fill="none" stroke="rgba(181,141,94,0.1)" stroke-width="1" stroke-dasharray="5 10"><animate attributeName="stroke-dashoffset" from="0" to="30" dur="4s" repeatCount="indefinite"/></circle>
            </svg>
            <style>@keyframes ringFade{0%,100%{opacity:0.3;transform:scale(0.85)}50%{opacity:0.8;transform:scale(1)}}</style>
          </div>
        </div>
      </div>

      <!-- D: Floor Plan -->
      <div>
        <p class="text-sm text-brand-gold font-medium mb-4 text-center">D. 家庭房间图</p>
        <div class="overflow-hidden rounded-3xl bg-bg-card border border-surface-06 p-6 md:p-10">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
            <!-- Rooms -->
            <div class="col-span-2 md:col-span-4 h-32 md:h-40 rounded-2xl bg-brand-gold/5 border border-brand-gold/15 flex flex-col items-center justify-center gap-1 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-gold/5 to-transparent" style="animation: roomScan 3s ease-in-out infinite"></div>
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="text-sm text-brand-gold font-medium">{isEn ? 'Living Room · Today\'s Family Diary' : '客厅 · 今日全家日记'}</span>
              <span class="text-[10px] text-text-muted">{isEn ? '4 members, 8 entries' : '4 位成员 · 8 篇日记'}</span>
            </div>
            {['卧室·妈妈','书房·爸爸','儿童房·宝宝','阳台·爷爷'].map((room,i) => (
              <div class="h-24 md:h-28 rounded-xl bg-surface-03 border border-surface-06 flex flex-col items-center justify-center gap-1 transition-all hover:bg-surface-04 hover:border-brand-gold/20 hover:scale-105 cursor-default"
                   style={{animation: `fadeInUp 0.5s ease-out ${i*0.1+0.2}s both`}}>
                <div class="w-8 h-8 rounded-full bg-brand-gold/10 flex items-center justify-center text-brand-gold text-xs font-bold">{room[0]}</div>
                <span class="text-[10px] md:text-xs text-text-muted">{room}</span>
                <span class="text-[9px] text-text-muted">{2+i} 篇</span>
              </div>
            ))}
          </div>
          <style>@keyframes roomScan{0%,100%{transform:translateX(-100%)}50%{transform:translateX(100%)}}</style>
        </div>
      </div>

    </div>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Easy Family Management' : '便捷家庭管理'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Support family creation, QR code invites, full family migration. Flexible join/leave mechanisms for all family scenarios.' : '支持创建家庭、扫码邀请、整家庭迁移，灵活的成员加入与退出机制，适配各类家庭使用场景。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Unified Diary View' : '全员日记聚合视图'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Timeline auto-merges all family records. Switch between full view and individual view. Open sharing with independent editing — clear permissions.' : '时间线自动合并全家记录，支持总览/单人切换查看，公开共享、独立编辑，权限清晰可控。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Daily Family Cover' : '每日家庭封面'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'System intelligently selects daily cover — photos or trajectory maps auto-generated. Preserve each day\'s exclusive family moment.' : '系统智能优选当日封面，照片、轨迹地图自动生成，沉淀每日家庭专属画面。'}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
</style>
