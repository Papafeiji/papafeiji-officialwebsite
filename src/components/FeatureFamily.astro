---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="family" class="relative py-32 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_50%,rgba(181,141,94,0.06),transparent)]"></div>
  <div class="relative max-w-5xl mx-auto">

    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('family.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('family.title.1')}<span class="gradient-text">{_('family.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">
        {_('family.subtitle')}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mb-8">
      <!-- Create & Join -->
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Family Creation & Joining' : '家庭创建与加入规则'}</h3>
        <ul class="space-y-2 text-text-secondary text-sm leading-relaxed">
          {isEn ? <>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> Upgrade personal family to shared family — you become the family admin</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> Generate invite links and QR codes for quick member joining</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> If a new member was a family admin, their entire family & history migrate in</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> Up to 6 members per shared family. One family at a time per user</li>
          </> : <>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 任意用户可将个人家庭升级为共享家庭，成为家庭主理人</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 支持生成专属邀请链接、二维码，扫码即可快速加入</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 新成员为原家庭主理人时，原有家庭全部日记整体迁入新家庭</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 单个共享家庭最多 6 名成员，每人同一时间仅能加入一个共享家庭</li>
          </>}
        </ul>
      </div>

      <!-- Merged Diary View -->
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Merged Diary View' : '合并日记视图'}</h3>
        <ul class="space-y-2 text-text-secondary text-sm leading-relaxed">
          {isEn ? <>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> Timeline auto-aggregates all members' diaries sorted by date, with avatars & entry counts</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> Daily detail page shows member tabs — view all or switch to a single member</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> Members can view all diaries but can only edit and delete their own entries</li>
          </> : <>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 首页时间线自动聚合所有成员日记，按日期排序，标注成员头像和记录篇数</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 日记详情页展示各成员分页标签，支持全员合并视图或单一成员视图</li>
            <li class="flex gap-2"><span class="text-brand-gold shrink-0">-</span> 成员之间可互相查看全部日记，但仅能编辑、删除自己撰写的条目</li>
          </>}
        </ul>
      </div>
    </div>

    <!-- Additional features -->
    <div class="grid md:grid-cols-2 gap-6">
      <div class="p-6 rounded-2xl bg-bg-card border border-surface-06">
        <h3 class="text-base font-semibold text-text-primary mb-3">{isEn ? 'Daily Family Cover' : '家庭共享封面'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Auto-generated daily cover with priority: manual cover > latest photo > member trajectory map > default cover. All members see the same cover.' : '每日自动生成共享封面，按优先级：成员手动设置 > 当日最新照片 > 全员轨迹地图 > 系统默认封面。所有成员看到的封面完全一致。'}
        </p>
      </div>
      <div class="p-6 rounded-2xl bg-bg-card border border-surface-06">
        <h3 class="text-base font-semibold text-text-primary mb-3">{isEn ? 'Member Management' : '家庭成员管理'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Members can leave anytime, returning to personal mode. Admins can remove members or dissolve the family. All data is preserved — no diary is ever lost.' : '成员可随时退出返回个人模式，主理人可移除成员或解散家庭。所有历史日记保留不丢失，数据主权不受影响。'}
        </p>
      </div>
    </div>
  </div>
</section>
