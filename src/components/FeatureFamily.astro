---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="family" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_50%,rgba(181,141,94,0.06),transparent)]"></div>
  <div class="relative max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('family.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('family.title.1')}<span class="gradient-text">{_('family.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('family.subtitle')}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Easy Family Management' : '便捷家庭管理'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Support family creation, QR code invites, full family migration. Flexible join/leave mechanisms for all family scenarios.' : '支持创建家庭、扫码邀请、整家庭迁移，灵活的成员加入与退出机制，适配各类家庭使用场景。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Unified Diary View' : '全员日记聚合视图'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Timeline auto-merges all family records. Switch between full view and individual view. Open sharing with independent editing — clear permissions.' : '时间线自动合并全家记录，支持总览/单人切换查看，公开共享、独立编辑，权限清晰可控。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Daily Family Cover' : '每日家庭封面'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'System intelligently selects daily cover — photos or trajectory maps auto-generated. Preserve each day\'s exclusive family moment.' : '系统智能优选当日封面，照片、轨迹地图自动生成，沉淀每日家庭专属画面。'}
        </p>
      </div>
    </div>

    <div class="p-6 rounded-2xl bg-bg-card border border-surface-06 text-center">
      <p class="text-text-secondary text-sm">
        {isEn ? 'Complete member permissions: admins manage members and dissolve families; members can leave freely. All historical memories are permanently preserved.' : '完善成员权限体系：主理人可管理成员、解散家庭；成员可自由退出，所有历史记忆永久保留不丢失。'}
      </p>
    </div>
  </div>
</section>
