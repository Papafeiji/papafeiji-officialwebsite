---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <div class="absolute inset-0 bg-gradient-to-b from-bg-deep via-bg-card to-bg-deep"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(181,141,94,0.15),transparent)]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-gold/10 rounded-full blur-[120px] animate-pulse-glow"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div class="mb-10 animate-float">
      <div class="relative inline-block">
        <div class="absolute inset-0 bg-brand-gold/20 rounded-3xl blur-2xl"></div>
        <img src="/papafeiji.png" alt={_('site.name')} width="112" height="112" class="relative w-28 h-28 rounded-2xl" fetchpriority="high" decoding="async" />
      </div>
    </div>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-tight">
      <span class="text-text-primary">{_('hero.title.part1')}</span><br />
      <span class="gradient-text">{_('hero.title.part2')}</span>
    </h1>

    <p class="text-xl md:text-2xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      {_('hero.subtitle')}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a href="#self-host" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-brand-gold text-contrast-btn-text font-semibold hover:bg-brand-warm transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><path d="M6 6h.01"/><path d="M6 18h.01"/></svg>
        {_('hero.cta.deploy')}
      </a>
      <a href="#ai" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-surface-04 border border-surface-08 text-text-primary font-semibold hover:bg-surface-08 transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        {_('hero.cta.ai')}
      </a>
    </div>

    <div class="max-w-lg mx-auto">
      <div class="code-block text-left">
        <div class="code-header">
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="ml-2 text-xs text-text-muted">Terminal</span>
        </div>
        <div class="code-body">
          <div><span class="prompt">$</span> <span class="cmd">curl -fsSL https://raw.githubusercontent.com/Papafeiji/pathmemos/open/scripts/install.sh | bash</span></div>
        </div>
      </div>
    </div>
  </div>
</section>
