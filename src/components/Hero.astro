---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg-deep via-bg-card to-bg-deep"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(181,141,94,0.15),transparent)]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-gold/10 rounded-full blur-[120px] animate-pulse-glow"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Logo with glow -->
    <div class="mb-10 animate-float">
      <div class="relative inline-block">
        <div class="absolute inset-0 bg-brand-gold/20 rounded-3xl blur-2xl"></div>
        <img src="/papafeiji.png" alt={_('site.name')} width="112" height="112" class="relative w-28 h-28 rounded-2xl" fetchpriority="high" decoding="async" />
      </div>
    </div>

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-04 border border-surface-08 mb-8">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      <span class="text-sm text-text-secondary">{_('hero.badge')}</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight">
      <span class="gradient-text">{_('hero.title.part1')}</span><br />
      <span class="text-text-primary">{_('hero.title.part2')}</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-xl md:text-2xl text-text-secondary max-w-2xl mx-auto mb-12 leading-relaxed">
      {_('hero.subtitle')}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#open-source" class="group inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-brand-gold text-contrast-btn-text font-semibold hover:bg-brand-warm transition-colors">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        {_('hero.cta.deploy')}
      </a>
      <a href="https://github.com/Papafeiji/pathmemos" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-surface-04 border border-surface-08 text-text-primary font-semibold hover:bg-surface-08 transition-colors">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        {_('hero.cta.github')}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-muted">
    <span class="text-xs tracking-widest uppercase">{_('hero.scrollHint')}</span>
    <div class="w-5 h-8 rounded-full border border-surface-20 flex justify-center pt-1">
      <div class="w-1 h-2 rounded-full bg-brand-gold animate-bounce"></div>
    </div>
  </div>
</section>
