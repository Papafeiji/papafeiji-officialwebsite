---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section class="relative min-h-[100svh] flex flex-col items-center justify-center overflow-hidden pt-16">
  <div class="absolute inset-0 bg-gradient-to-b from-bg-deep via-bg-card to-bg-deep"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(181,141,94,0.15),transparent)]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-brand-gold/10 rounded-full blur-[80px] md:blur-[120px] animate-pulse-glow"></div>

  <!-- Floating particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-1 h-1 rounded-full bg-brand-gold/60" style="left:18%;top:22%;animation: particleFloat 9s ease-in-out infinite"></div>
    <div class="absolute w-1.5 h-1.5 rounded-full bg-brand-gold/40" style="left:78%;top:28%;animation: particleFloat 11s ease-in-out infinite 2s"></div>
    <div class="absolute w-1 h-1 rounded-full bg-brand-warm/50" style="left:28%;top:72%;animation: particleFloat 10s ease-in-out infinite 4s"></div>
    <div class="absolute w-2 h-2 rounded-full bg-brand-gold/30" style="left:72%;top:76%;animation: particleFloat 12s ease-in-out infinite 1s"></div>
    <div class="absolute w-1 h-1 rounded-full bg-brand-warm/40" style="left:52%;top:14%;animation: particleFloat 8s ease-in-out infinite 3s"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center w-full min-w-0">
    <div class="mb-10 animate-float">
      <div class="relative inline-block">
        <div class="absolute inset-0 bg-brand-gold/20 rounded-3xl blur-2xl"></div>
        <img src="/newlogo-128.webp" srcset="/newlogo-128.webp 1x, /newlogo-256.webp 2x" alt={_('site.name')} width="144" height="144" class="relative w-36 h-36 rounded-2xl" fetchpriority="high" decoding="async" />
      </div>
    </div>

    <h1 class="text-4xl md:text-7xl font-bold tracking-tight mb-6 md:mb-8 leading-tight">
      <span class="text-text-primary">{_('hero.title.part1')}</span><br />
      <span class="gradient-text">{_('hero.title.part2')}</span>
    </h1>

    <p class="text-lg md:text-2xl text-text-secondary mb-8 md:mb-10 leading-relaxed break-words">
      {_('hero.subtitle')}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10 md:mb-12">
      <a href="weixin://dl/business/?appid=wxe56d190a14826b0d&path=pages/index/index" class="inline-flex items-center justify-start gap-3 px-8 py-3 rounded-xl bg-surface-04 border border-brand-gold/30 text-text-primary font-semibold hover:bg-surface-08 hover:border-brand-gold/50 transition-all min-w-[200px]">
        <img src="/newlogo-32.webp" srcset="/newlogo-32.webp 1x, /newlogo-128.webp 2x" alt="" width="32" height="32" class="w-8 h-8 rounded shrink-0" fetchpriority="high" decoding="async" />
        {_('hero.cta.miniprogram')}
      </a>
      <a href="https://github.com/Papafeiji/pathmemos" target="_blank" rel="noopener" class="inline-flex items-center justify-start gap-3 px-8 py-3 rounded-xl bg-surface-04 border border-surface-06 text-text-primary font-semibold hover:bg-surface-08 transition-colors min-w-[200px]">
        <svg class="w-6 h-6 shrink-0" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        {_('hero.cta.github')}
      </a>
    </div>

    <div class="w-full max-w-3xl mx-auto">
      <div class="code-block text-left">
        <div class="code-header">
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="ml-2 text-xs text-text-muted">{_('hero.terminal')}</span>
          <button id="copy-btn" class="ml-auto flex items-center gap-1 px-3 py-1 rounded-lg bg-surface-04 border border-surface-06 text-xs text-text-secondary hover:text-text-primary hover:bg-surface-08 transition-all cursor-pointer shrink-0" data-copy-text={_('hero.copy')} data-copied-text={_('hero.copied')}>
            <svg id="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            <span id="copy-text">{_('hero.copy')}</span>
          </button>
        </div>
        <div class="code-body">
          <div class="whitespace-nowrap text-xs md:text-sm"><span class="prompt">$</span> <span class="cmd" id="install-cmd">curl -fsSL https://raw.githubusercontent.com/Papafeiji/pathmemos/open/scripts/install.sh | bash</span></div>
        </div>
      </div>
      <p class="text-xs md:text-sm text-text-muted mt-4 leading-relaxed">
        {isEn ? 'Works on Linux and macOS. The one-liner installs everything for you. After installation, fill in your backend URL and API Key in the Mini Program settings — all data routes to your own server.' : '支持 Linux 和 macOS，一行命令完成全部安装。部署后在小程序设置页填写后端地址与 API Key，即可将所有数据路由至个人服务器。'}
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes particleFloat {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
    25% { transform: translateY(-20px) translateX(10px); opacity: 0.7; }
    50% { transform: translateY(-40px) translateX(-5px); opacity: 0.4; }
    75% { transform: translateY(-15px) translateX(-10px); opacity: 0.6; }
  }
</style>

<script src="/scripts/hero-copy.js" defer></script>
