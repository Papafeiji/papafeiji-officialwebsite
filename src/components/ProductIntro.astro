---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---
<section id="intro" class="relative py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
      <span class="text-sm text-brand-gold font-medium">{_('intro.badge')}</span>
    </div>
    <p class="text-lg md:text-xl text-text-secondary leading-relaxed">
      {_('intro.content')}
    </p>
  </div>
</section>
