---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---
<section id="background" class="relative py-32 px-6">
  <div class="max-w-4xl mx-auto text-center">
    
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('background.badge')}</span>
      </div>
    

    
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-8 leading-tight">
        {_('background.title.1')}<br />
        <span class="gradient-text">{_('background.title.2')}</span>
      </h2>
    

    
      <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-16 leading-relaxed">
        {_('background.subtitle')}
      </p>
    

    <div class="grid md:grid-cols-3 gap-6">
      
        <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 text-left">
          <div class="w-12 h-12 rounded-xl bg-surface-04 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><rect width="20" height="14" x="2" y="5" rx="2" ry="2"/><path d="M12 17V5"/><path d="M8 9h8"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{_('background.card1.title')}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{_('background.card1.desc')}</p>
        </div>
      

      
        <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 text-left">
          <div class="w-12 h-12 rounded-xl bg-surface-04 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{_('background.card2.title')}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{_('background.card2.desc')}</p>
        </div>
      

      
        <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 text-left">
          <div class="w-12 h-12 rounded-xl bg-surface-04 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><path d="M4 4h16v16H4z"/><path d="M4 9h16"/><path d="M9 4v16"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{_('background.card3.title')}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{_('background.card3.desc')}</p>
        </div>
      
    </div>
  </div>
</section>
