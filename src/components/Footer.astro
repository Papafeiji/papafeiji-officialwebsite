---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---
<footer class="border-t border-surface-06 py-12 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <img src="/papafeiji.png" alt={_('site.name')} width="32" height="32" class="w-8 h-8 rounded-lg opacity-60" loading="lazy" decoding="async" />
      <span class="text-text-muted text-sm">{_('site.name')} · {_('site.tagline')}</span>
    </div>

    <div class="flex items-center gap-6 text-sm text-text-muted">
      <a href={lang === 'en' ? '/en/tutorial/privacy-policy' : '/tutorial/privacy-policy'} class="hover:text-text-secondary transition-colors">{_('footer.privacy')}</a>
      <a href={lang === 'en' ? '/en/tutorial' : '/tutorial'} class="hover:text-text-secondary transition-colors">{_('footer.tutorial')}</a>
      <a href="https://github.com/Papafeiji/pathmemos" target="_blank" rel="noopener" class="hover:text-text-secondary transition-colors">GitHub</a>
    </div>

    <div class="text-xs text-text-muted text-center md:text-right">
      <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" class="hover:text-text-secondary transition-colors">
        {_('site.copyright')}
      </a>

    </div>
  </div>
</footer>
