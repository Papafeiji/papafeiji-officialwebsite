---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---
<section class="relative py-32 px-6">
  <div class="max-w-4xl mx-auto text-center">
    
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('problem.badge')}</span>
      </div>
    

    
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-8 leading-tight">
        {_('problem.title.1')}<br />
        <span class="text-text-muted">{_('problem.title.2')}</span><span class="gradient-text">{_('problem.title.3')}</span><span class="text-text-muted">{_('problem.title.4')}</span>
      </h2>
    

    
      <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-16 leading-relaxed">
        {_('problem.subtitle')}
      </p>
    

    <div class="grid md:grid-cols-3 gap-6">
      
        <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 text-left">
          <div class="w-12 h-12 rounded-xl bg-surface-04 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{_('problem.card1.title')}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{_('problem.card1.desc')}</p>
        </div>
      

      
        <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 text-left">
          <div class="w-12 h-12 rounded-xl bg-surface-04 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{_('problem.card2.title')}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{_('problem.card2.desc')}</p>
        </div>
      

      
        <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 text-left">
          <div class="w-12 h-12 rounded-xl bg-surface-04 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-gold"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{_('problem.card3.title')}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{_('problem.card3.desc')}</p>
        </div>
      
    </div>
  </div>
</section>
