---
import { t } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = (key: any) => t(lang, key as any);

const platforms = [
  { name: "豆包", color: "#3B82F6", initial: "豆" },
  { name: "Kimi", color: "#10B981", initial: "K" },
  { name: "通义千问", color: "#8B5CF6", initial: "千" },
  { name: "ChatGPT", color: "#F97316", initial: "C" },
  { name: "Claude", color: "#D97706", initial: "Cl" },
  { name: "文心一言", color: "#EC4899", initial: "文" },
  { name: "DeepSeek", color: "#06B6D4", initial: "D" },
  { name: "Gemini", color: "#6366F1", initial: "G" }
];
---

<section id="integrations" class="relative py-32 px-6">
  <div class="max-w-5xl mx-auto">
    
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
          <span class="text-sm text-brand-gold font-medium">{_('integrations.badge')}</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
          {_('integrations.title.1')}<span class="gradient-text">{_('integrations.title.2')}</span>
        </h2>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          {_('integrations.subtitle')}
        </p>
      </div>
    

    
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {platforms.map((p) => (
          <div class="group flex flex-col items-center gap-4 p-6 rounded-2xl bg-bg-card border border-surface-06 hover:border-surface-10 transition-all">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-lg font-bold text-white transition-transform group-hover:scale-110" style={`background: ${p.color}20; color: ${p.color};`}>
              {p.initial}
            </div>
            <span class="text-sm text-text-secondary font-medium">{p.name}</span>
          </div>
        ))}
      </div>
    

    
      <div class="mt-12 p-6 rounded-2xl bg-bg-card border border-surface-06 text-center">
        <p class="text-text-secondary text-sm" set:html={_('integrations.note')} />
      </div>
    
  </div>
</section>
