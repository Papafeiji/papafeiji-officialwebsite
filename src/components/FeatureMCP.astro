---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="mcp" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('mcp.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('mcp.title.1')}<span class="gradient-text">{_('mcp.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('mcp.subtitle')}</p>
    </div>

    <!-- Clean editorial illustration: Memory Streams -->
    <div class="relative mb-20 overflow-hidden rounded-3xl bg-bg-card border border-surface-06 px-4 md:px-10 py-10 md:py-14">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        
        <!-- Left: Memory Source -->
        <div class="flex flex-col items-center gap-3 shrink-0">
          <div class="relative">
            <div class="w-20 h-20 md:w-28 md:h-28 rounded-2xl bg-brand-gold/10 border border-brand-gold/20 flex items-center justify-center">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5" class="md:w-[56px] md:h-[56px]">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <path d="M14 2v6h6"/>
                <path d="M12 18v-6"/>
                <path d="M9 15h6"/>
              </svg>
            </div>
            <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-emerald-400 animate-pulse"></div>
          </div>
          <span class="text-sm md:text-base text-text-primary font-semibold">{isEn ? 'Your Memories' : '你的记忆'}</span>
          <div class="flex gap-1.5">
            <span class="text-[10px] text-text-muted bg-surface-03 px-2 py-0.5 rounded-full">日记</span>
            <span class="text-[10px] text-text-muted bg-surface-03 px-2 py-0.5 rounded-full">位置</span>
            <span class="text-[10px] text-text-muted bg-surface-03 px-2 py-0.5 rounded-full">照片</span>
          </div>
        </div>

        <!-- Animated flow stream: Source → Hub -->
        <div class="hidden md:flex flex-1 items-center relative h-10">
          <svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none">
            <defs>
              <linearGradient id="stream-in" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="rgba(181,141,94,0.6)"/>
                <stop offset="100%" stop-color="rgba(181,141,94,0.8)"/>
              </linearGradient>
            </defs>
            <line x1="0" y1="20" x2="145" y2="20" stroke="url(#stream-in)" stroke-width="2"/>
            <circle r="2.5" fill="#B58D5E" opacity="0.8">
              <animateMotion dur="2s" repeatCount="indefinite" path="M0,20 Q75,15 145,20"/>
            </circle>
            <circle r="2" fill="#B58D5E" opacity="0.5">
              <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.6s" path="M0,20 Q75,25 145,20"/>
            </circle>
          </svg>
        </div>

        <!-- Center: PathMemos Hub -->
        <div class="flex flex-col items-center gap-2 shrink-0">
          <div class="relative">
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-brand-gold/15 border-2 border-brand-gold/30 flex items-center justify-center shadow-lg shadow-brand-gold/20">
              <img src="/papafeiji.png" alt="PathMemos" width="36" height="36" class="w-9 h-9 md:w-11 md:h-11 rounded-lg" />
            </div>
            <div class="absolute inset-0 rounded-2xl bg-brand-gold/10 animate-ping" style="animation-duration:2.5s"></div>
          </div>
          <span class="text-sm md:text-base text-brand-gold font-semibold">PathMemos</span>
          <span class="text-[10px] md:text-xs text-text-muted">{isEn ? 'MCP Memory Hub' : 'MCP 记忆中枢'}</span>
        </div>

        <!-- Animated flow stream: Hub → AI tools -->
        <div class="hidden md:flex flex-1 items-center relative h-10">
          <svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none">
            <defs>
              <linearGradient id="stream-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="rgba(181,141,94,0.5)"/>
                <stop offset="50%" stop-color="rgba(181,141,94,0.8)"/>
                <stop offset="100%" stop-color="rgba(181,141,94,0.2)"/>
              </linearGradient>
            </defs>
            <!-- Main stream -->
            <line x1="0" y1="20" x2="290" y2="20" stroke="url(#stream-gradient)" stroke-width="2"/>
            <!-- Secondary streams fanning out -->
            <line x1="200" y1="20" x2="290" y2="8" stroke="rgba(168,85,247,0.4)" stroke-width="1.5"/>
            <line x1="200" y1="20" x2="290" y2="16" stroke="rgba(249,115,22,0.4)" stroke-width="1.5"/>
            <line x1="200" y1="20" x2="290" y2="24" stroke="rgba(6,182,212,0.4)" stroke-width="1.5"/>
            <line x1="200" y1="20" x2="290" y2="32" stroke="rgba(16,185,129,0.4)" stroke-width="1.5"/>
            <!-- Flowing dots -->
            <circle r="2.5" fill="#B58D5E" opacity="0.8">
              <animateMotion dur="2.5s" repeatCount="indefinite" path="M0,20 Q150,15 290,20"/>
            </circle>
            <circle r="2" fill="#B58D5E" opacity="0.6">
              <animateMotion dur="3s" repeatCount="indefinite" begin="0.8s" path="M0,20 Q150,25 290,20"/>
            </circle>
            <circle r="2.5" fill="#8B5CF6" opacity="0.7">
              <animateMotion dur="2.8s" repeatCount="indefinite" begin="1.5s" path="M200,20 Q240,10 290,8"/>
            </circle>
            <circle r="2.5" fill="#D97706" opacity="0.7">
              <animateMotion dur="3.2s" repeatCount="indefinite" begin="2s" path="M200,20 Q240,18 290,16"/>
            </circle>
            <circle r="2.5" fill="#06B6D4" opacity="0.7">
              <animateMotion dur="2.6s" repeatCount="indefinite" begin="1s" path="M200,20 Q240,24 290,24"/>
            </circle>
            <circle r="2.5" fill="#10B981" opacity="0.7">
              <animateMotion dur="3s" repeatCount="indefinite" begin="2.5s" path="M200,20 Q240,30 290,32"/>
            </circle>
          </svg>
        </div>

        <!-- Mobile arrow -->
        <div class="flex md:hidden text-2xl text-brand-gold animate-bounce">↓</div>

        <!-- Right: AI Tools - clean list -->
        <div class="flex flex-col gap-3 shrink-0">
          <div class="flex items-center gap-3 group cursor-default">
            <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center transition-all group-hover:bg-purple-500/20 group-hover:scale-110">
              <span class="text-purple-400 text-sm font-bold">Cu</span>
            </div>
            <div>
              <div class="text-sm text-text-primary font-medium">Cursor</div>
              <div class="text-[10px] text-text-muted">MCP 协议</div>
            </div>
          </div>
          <div class="flex items-center gap-3 group cursor-default">
            <div class="w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center transition-all group-hover:bg-orange-500/20 group-hover:scale-110">
              <span class="text-orange-400 text-sm font-bold">Cl</span>
            </div>
            <div>
              <div class="text-sm text-text-primary font-medium">Claude</div>
              <div class="text-[10px] text-text-muted">MCP 协议</div>
            </div>
          </div>
          <div class="flex items-center gap-3 group cursor-default">
            <div class="w-10 h-10 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center transition-all group-hover:bg-cyan-500/20 group-hover:scale-110">
              <span class="text-cyan-400 text-sm font-bold">D</span>
            </div>
            <div>
              <div class="text-sm text-text-primary font-medium">DeepSeek</div>
              <div class="text-[10px] text-text-muted">API Key</div>
            </div>
          </div>
          <div class="flex items-center gap-3 group cursor-default">
            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center transition-all group-hover:bg-emerald-500/20 group-hover:scale-110">
              <span class="text-emerald-400 text-sm font-bold">O</span>
            </div>
            <div>
              <div class="text-sm text-text-primary font-medium">OpenAI</div>
              <div class="text-[10px] text-text-muted">API Key</div>
            </div>
          </div>
        </div>

      </div>

      <!-- Bottom note -->
      <div class="text-center mt-10">
        <p class="text-xs text-text-muted">
          {isEn ? 'Standard MCP protocol endpoint — one memory source, all AIs can access. Open-source edition includes all VIP features.' : '标准 MCP 协议端点 — 一处记忆，全部 AI 共享读取。开源版解锁全部 VIP 功能。'}
        </p>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Write · Smart Archiving' : '记忆写入 · 智能沉淀'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'AI auto-summarizes conversations, extracts key insights, and batch-archives them as personal memories. Supports local draft caching and offline retry — your memories are never lost.' : 'AI 可自动总结对话、提炼关键信息，批量归档为个人记忆。支持本地草稿缓存、断网续传，保证记忆不丢失。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Read · Full Recall' : '记忆读取 · 全域召回'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Batch retrieve all diaries, trajectories, and archived memories by time range. Let AI understand your habits, past experiences, and personal preferences.' : '支持按时间范围批量检索全部日记、轨迹与存档记忆，让 AI 理解你的生活习惯、过往经历与个人偏好。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Secure & Controllable' : '安全可控机制'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Self-manage API keys with rotation support, rate limiting, and caching. Private and cloud data are fully isolated — absolutely private and secure.' : '自主管理 API 密钥，支持随时轮换、限流保护、缓存加速，私有化数据与云端数据完全隔离，绝对私密安全。'}
        </p>
      </div>
    </div>
  </div>
</section>
