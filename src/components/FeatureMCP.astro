---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---

<style>
  @keyframes flowRight { to { stroke-dashoffset: -24; } }
  @keyframes flowLeft { to { stroke-dashoffset: 24; } }
  @keyframes orbPulse { 0%,100%{opacity:0.4;transform:scale(1)} 50%{opacity:1;transform:scale(1.3)} }
  @keyframes spokeRotate { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

<section id="mcp" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('mcp.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('mcp.title.1')}<span class="gradient-text">{_('mcp.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('mcp.subtitle')}</p>
    </div>

    <!-- Hub-and-spoke connection diagram -->
    <div class="relative mb-20 h-48 md:h-72 overflow-hidden rounded-3xl bg-bg-card border border-surface-06">
      <div class="absolute inset-0 flex items-center justify-center">
        <!-- Central hub -->
        <div class="absolute z-20 flex flex-col items-center" style="left:50%;top:50%;transform:translate(-50%,-50%)">
          <div class="relative">
            <div class="w-14 h-14 md:w-20 md:h-20 rounded-2xl bg-brand-gold/20 border-2 border-brand-gold/40 flex items-center justify-center shadow-lg shadow-brand-gold/20">
              <img src="/papafeiji.png" alt="" width="40" height="40" class="w-8 h-8 md:w-10 md:h-10 rounded-lg" />
            </div>
            <div class="absolute inset-0 w-14 h-14 md:w-20 md:h-20 rounded-2xl bg-brand-gold/10 animate-ping" style="animation-duration:3s"></div>
          </div>
          <span class="text-[10px] md:text-xs text-brand-gold mt-2 md:mt-3 font-medium">PathMemos</span>
        </div>

        <!-- Orbiting rings - smaller on mobile -->
        <div class="absolute w-36 h-36 md:w-48 md:h-48 rounded-full border border-brand-gold/10" style="left:50%;top:50%;transform:translate(-50%,-50%);animation: spokeRotate 20s linear infinite"></div>
        <div class="absolute w-28 h-28 md:w-36 md:h-36 rounded-full border border-brand-gold/8" style="left:50%;top:50%;transform:translate(-50%,-50%);animation: spokeRotate 15s linear infinite reverse"></div>

        <!-- Connected AI tools -->
        <div class="absolute z-10" style="left:8%;top:25%">
          <div class="flex items-center gap-1.5">
            <div class="w-8 h-8 md:w-10 md:h-10 rounded-xl bg-purple-500/20 flex items-center justify-center text-purple-400 text-xs md:text-sm font-bold shadow-lg shadow-purple-500/10">Cu</div>
            <span class="text-[10px] md:text-xs text-text-muted">Cursor</span>
          </div>
        </div>
        <div class="absolute z-10" style="right:8%;top:25%">
          <div class="flex items-center gap-1.5">
            <span class="text-[10px] md:text-xs text-text-muted">Claude</span>
            <div class="w-8 h-8 md:w-10 md:h-10 rounded-xl bg-orange-500/20 flex items-center justify-center text-orange-400 text-xs md:text-sm font-bold shadow-lg shadow-orange-500/10">Cl</div>
          </div>
        </div>
        <div class="absolute z-10" style="left:8%;bottom:22%">
          <div class="flex items-center gap-1.5">
            <div class="w-8 h-8 md:w-10 md:h-10 rounded-xl bg-cyan-500/20 flex items-center justify-center text-cyan-400 text-xs md:text-sm font-bold shadow-lg shadow-cyan-500/10">D</div>
            <span class="text-[10px] md:text-xs text-text-muted">DeepSeek</span>
          </div>
        </div>
        <div class="absolute z-10" style="right:8%;bottom:22%">
          <div class="flex items-center gap-1.5">
            <span class="text-[10px] md:text-xs text-text-muted">OpenAI</span>
            <div class="w-8 h-8 md:w-10 md:h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center text-emerald-400 text-xs md:text-sm font-bold shadow-lg shadow-emerald-500/10">O</div>
          </div>
        </div>
      </div>

      <!-- Connection lines with flow animation -->
      <svg class="absolute inset-0 w-full h-full z-0" viewBox="0 0 720 280" preserveAspectRatio="none">
        <defs>
          <linearGradient id="conn-grad-1" x1="100%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="rgba(168,85,247,0.3)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/></linearGradient>
          <linearGradient id="conn-grad-2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="rgba(249,115,22,0.3)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/></linearGradient>
          <linearGradient id="conn-grad-3" x1="100%" y1="100%" x2="0%" y2="0%"><stop offset="0%" stop-color="rgba(6,182,212,0.3)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/></linearGradient>
          <linearGradient id="conn-grad-4" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="rgba(16,185,129,0.3)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/></linearGradient>
          <linearGradient id="conn-grad-5" x1="0%" y1="0%" x2="50%" y2="100%"><stop offset="0%" stop-color="rgba(59,130,246,0.3)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/></linearGradient>
        </defs>
        <g opacity="0.6">
          <line x1="58" y1="70" x2="360" y2="140" stroke="url(#conn-grad-1)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="662" y1="70" x2="360" y2="140" stroke="url(#conn-grad-2)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="58" y1="218" x2="360" y2="140" stroke="url(#conn-grad-3)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <line x1="662" y1="218" x2="360" y2="140" stroke="url(#conn-grad-4)" stroke-width="1.5" stroke-dasharray="6 4"/>
        </g>
      </svg>

      <!-- Floating data orbs -->
      <div class="absolute w-1.5 h-1.5 rounded-full bg-brand-gold/60" style="left:20%;top:38%;animation:orbPulse 3s ease-in-out infinite"></div>
      <div class="absolute w-1 h-1 rounded-full bg-purple-400/60" style="left:38%;top:30%;animation:orbPulse 2.5s ease-in-out infinite 0.5s"></div>
      <div class="absolute w-1.5 h-1.5 rounded-full bg-cyan-400/60" style="right:22%;top:55%;animation:orbPulse 3.5s ease-in-out infinite 1s"></div>
      <div class="absolute w-1 h-1 rounded-full bg-emerald-400/60" style="right:35%;top:35%;animation:orbPulse 2.8s ease-in-out infinite 0.8s"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Write · Smart Archiving' : '记忆写入 · 智能沉淀'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'AI auto-summarizes conversations, extracts key insights, and batch-archives them as personal memories. Supports local draft caching and offline retry — your memories are never lost.' : 'AI 可自动总结对话、提炼关键信息，批量归档为个人记忆。支持本地草稿缓存、断网续传，保证记忆不丢失。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Read · Full Recall' : '记忆读取 · 全域召回'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Batch retrieve all diaries, trajectories, and archived memories by time range. Let AI understand your habits, past experiences, and personal preferences.' : '支持按时间范围批量检索全部日记、轨迹与存档记忆，让 AI 理解你的生活习惯、过往经历与个人偏好。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Secure & Controllable' : '安全可控机制'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Self-manage API keys with rotation support, rate limiting, and caching. Private and cloud data are fully isolated — absolutely private and secure.' : '自主管理 API 密钥，支持随时轮换、限流保护、缓存加速，私有化数据与云端数据完全隔离，绝对私密安全。'}
        </p>
      </div>
    </div>
  </div>
</section>
