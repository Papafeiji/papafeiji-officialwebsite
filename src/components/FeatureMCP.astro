---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="mcp" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('mcp.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('mcp.title.1')}<span class="gradient-text">{_('mcp.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('mcp.subtitle')}</p>
    </div>

    <!-- A: NEURON NETWORK - brain-like mesh -->
    <div class="mb-12">
      <p class="text-sm text-brand-gold font-medium mb-4 text-center">A. 神经元记忆网络</p>
      <div class="relative h-56 md:h-72 overflow-hidden rounded-3xl bg-bg-card border border-surface-06" style="background:radial-gradient(ellipse at 50% 50%,rgba(181,141,94,0.05) 0%,transparent 70%)">
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 720 280" preserveAspectRatio="none">
          <defs>
            <radialGradient id="nglow"><stop offset="0%" stop-color="rgba(181,141,94,0.8)"/><stop offset="100%" stop-color="rgba(181,141,94,0)"/></radialGradient>
            <radialGradient id="pu"><stop offset="0%" stop-color="rgba(168,85,247,0.7)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
            <radialGradient id="or"><stop offset="0%" stop-color="rgba(249,115,22,0.7)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
            <radialGradient id="cy"><stop offset="0%" stop-color="rgba(6,182,212,0.7)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
            <radialGradient id="em"><stop offset="0%" stop-color="rgba(16,185,129,0.7)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
          </defs>
          <!-- Dendrite connections - organic curves -->
          <g opacity="0.25">
            <path d="M360 140 Q250 60 140 80" fill="none" stroke="#8B5CF6" stroke-width="2"/>
            <path d="M360 140 Q280 90 140 80" fill="none" stroke="#8B5CF6" stroke-width="1"/>
            <path d="M360 140 Q500 50 580 70" fill="none" stroke="#D97706" stroke-width="2"/>
            <path d="M360 140 Q480 80 580 70" fill="none" stroke="#D97706" stroke-width="1"/>
            <path d="M360 140 Q250 200 120 210" fill="none" stroke="#06B6D4" stroke-width="2"/>
            <path d="M360 140 Q200 180 120 210" fill="none" stroke="#06B6D4" stroke-width="1"/>
            <path d="M360 140 Q520 220 620 200" fill="none" stroke="#10B981" stroke-width="2"/>
            <path d="M360 140 Q500 190 620 200" fill="none" stroke="#10B981" stroke-width="1"/>
          </g>
          <!-- Small synapse nodes along paths -->
          <circle cx="240" cy="98" r="3" fill="#8B5CF6" opacity="0.6"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2s" repeatCount="indefinite"/></circle>
          <circle cx="460" cy="90" r="3" fill="#D97706" opacity="0.6"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2.3s" repeatCount="indefinite"/></circle>
          <circle cx="220" cy="170" r="3" fill="#06B6D4" opacity="0.6"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2.6s" repeatCount="indefinite"/></circle>
          <circle cx="490" cy="175" r="3" fill="#10B981" opacity="0.6"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2.9s" repeatCount="indefinite"/></circle>
          <!-- Center soma -->
          <circle cx="360" cy="140" r="22" fill="url(#nglow)" opacity="0.15"><animate attributeName="r" values="22;28;22" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="360" cy="140" r="12" fill="none" stroke="#B58D5E" stroke-width="1.5" opacity="0.6"/>
          <image href="/papafeiji.png" x="350" y="130" width="20" height="20" style="border-radius:4px"/>
          <!-- Endpoint nodes -->
          <circle cx="140" cy="80" r="10" fill="url(#pu)" opacity="0.4"><animate attributeName="r" values="10;13;10" dur="2s" repeatCount="indefinite"/></circle>
          <circle cx="580" cy="70" r="10" fill="url(#or)" opacity="0.4"><animate attributeName="r" values="10;13;10" dur="2.5s" repeatCount="indefinite"/></circle>
          <circle cx="120" cy="210" r="10" fill="url(#cy)" opacity="0.4"><animate attributeName="r" values="10;13;10" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="620" cy="200" r="10" fill="url(#em)" opacity="0.4"><animate attributeName="r" values="10;13;10" dur="2.8s" repeatCount="indefinite"/></circle>
        </svg>
        <div class="absolute z-10" style="left:17%;top:24%"><span class="text-[10px] text-purple-400 font-medium">Cursor</span></div>
        <div class="absolute z-10" style="right:18%;top:20%"><span class="text-[10px] text-orange-400 font-medium">Claude</span></div>
        <div class="absolute z-10" style="left:15%;bottom:28%"><span class="text-[10px] text-cyan-400 font-medium">DeepSeek</span></div>
        <div class="absolute z-10" style="right:13%;bottom:30%"><span class="text-[10px] text-emerald-400 font-medium">OpenAI</span></div>
      </div>
    </div>

    <!-- B: CONSTELLATION - stars and sky -->
    <div class="mb-12">
      <p class="text-sm text-brand-gold font-medium mb-4 text-center">B. 星座星图</p>
      <div class="relative h-56 md:h-72 overflow-hidden rounded-3xl bg-bg-card border border-surface-06" style="background:linear-gradient(180deg,rgba(10,10,30,0.6) 0%,rgba(10,10,20,0.8) 100%)">
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 720 280" preserveAspectRatio="none">
          <defs>
            <filter id="b-star"><feGaussianBlur stdDeviation="1.5"/></filter>
            <filter id="b-big"><feGaussianBlur stdDeviation="3"/></filter>
          </defs>
          <!-- Random background stars -->
          <circle cx="45" cy="30" r="1" fill="#fff" opacity="0.3"><animate attributeName="opacity" values="0.1;0.5;0.1" dur="4s" repeatCount="indefinite"/></circle>
          <circle cx="120" cy="60" r="0.8" fill="#fff" opacity="0.2"><animate attributeName="opacity" values="0.1;0.4;0.1" dur="3.5s" repeatCount="indefinite"/></circle>
          <circle cx="200" cy="25" r="1.2" fill="#fff" opacity="0.25"><animate attributeName="opacity" values="0.1;0.6;0.1" dur="5s" repeatCount="indefinite"/></circle>
          <circle cx="300" cy="45" r="0.6" fill="#fff" opacity="0.3"/>
          <circle cx="420" cy="35" r="1" fill="#fff" opacity="0.2"><animate attributeName="opacity" values="0.15;0.5;0.15" dur="3.8s" repeatCount="indefinite"/></circle>
          <circle cx="550" cy="50" r="0.8" fill="#fff" opacity="0.25"/>
          <circle cx="650" cy="30" r="1.1" fill="#fff" opacity="0.2"><animate attributeName="opacity" values="0.1;0.45;0.1" dur="4.2s" repeatCount="indefinite"/></circle>
          <circle cx="80" cy="140" r="0.7" fill="#fff" opacity="0.3"/>
          <circle cx="180" cy="230" r="0.9" fill="#fff" opacity="0.2"/>
          <circle cx="400" cy="250" r="0.5" fill="#fff" opacity="0.35"/>
          <circle cx="500" cy="230" r="0.8" fill="#fff" opacity="0.25"/>
          <circle cx="600" cy="240" r="0.6" fill="#fff" opacity="0.3"/>
          <circle cx="250" cy="180" r="0.7" fill="#fff" opacity="0.2"/>
          <circle cx="480" cy="150" r="0.9" fill="#fff" opacity="0.15"/>
          <!-- Constellation lines -->
          <g opacity="0.25">
            <line x1="360" y1="100" x2="120" y2="70"  stroke="#8B5CF6" stroke-width="1" stroke-dasharray="3 6"/>
            <line x1="360" y1="100" x2="580" y2="60"  stroke="#D97706" stroke-width="1" stroke-dasharray="3 6"/>
            <line x1="360" y1="100" x2="140" y2="200" stroke="#06B6D4" stroke-width="1" stroke-dasharray="3 6"/>
            <line x1="360" y1="100" x2="600" y2="210" stroke="#10B981" stroke-width="1" stroke-dasharray="3 6"/>
            <line x1="120" y1="70"  x2="140" y2="200" stroke="#8B5CF6" stroke-width="0.5" stroke-dasharray="2 8"/>
            <line x1="580" y1="60"  x2="600" y2="210" stroke="#D97706" stroke-width="0.5" stroke-dasharray="2 8"/>
          </g>
          <!-- Main star - PathMemos -->
          <circle cx="360" cy="100" r="5" fill="#B58D5E" filter="url(#b-big)"><animate attributeName="r" values="5;7;5" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="360" cy="100" r="10" fill="none" stroke="#B58D5E" stroke-width="0.5" opacity="0.3"/>
          <line x1="355" y1="100" x2="365" y2="100" stroke="#B58D5E" stroke-width="1.5" opacity="0.8"/>
          <line x1="360" y1="95" x2="360" y2="105" stroke="#B58D5E" stroke-width="1.5" opacity="0.8"/>
          <!-- Colored stars -->
          <circle cx="120" cy="70" r="4" fill="#8B5CF6" filter="url(#b-star)"><animate attributeName="opacity" values="0.4;0.9;0.4" dur="2.5s" repeatCount="indefinite"/></circle>
          <circle cx="580" cy="60" r="4" fill="#D97706" filter="url(#b-star)"><animate attributeName="opacity" values="0.4;0.9;0.4" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="140" cy="200" r="4" fill="#06B6D4" filter="url(#b-star)"><animate attributeName="opacity" values="0.4;0.9;0.4" dur="2.8s" repeatCount="indefinite"/></circle>
          <circle cx="600" cy="210" r="4" fill="#10B981" filter="url(#b-star)"><animate attributeName="opacity" values="0.4;0.9;0.4" dur="3.5s" repeatCount="indefinite"/></circle>
        </svg>
        <div class="absolute z-10" style="left:14%;top:22%"><span class="text-[10px] text-purple-400/70">Cursor</span></div>
        <div class="absolute z-10" style="right:17%;top:20%"><span class="text-[10px] text-orange-400/70">Claude</span></div>
        <div class="absolute z-10" style="left:16%;bottom:30%"><span class="text-[10px] text-cyan-400/70">DeepSeek</span></div>
        <div class="absolute z-10" style="right:14%;bottom:28%"><span class="text-[10px] text-emerald-400/70">OpenAI</span></div>
        <div class="absolute z-10" style="left:50%;top:36%;transform:translateX(-50%)"><span class="text-[10px] text-brand-gold font-medium">✦ PathMemos</span></div>
      </div>
    </div>

    <!-- C: CARD SHELVES - archive/library aesthetic -->
    <div class="mb-12">
      <p class="text-sm text-brand-gold font-medium mb-4 text-center">C. 记忆卡片架</p>
      <div class="relative h-56 md:h-72 overflow-hidden rounded-3xl bg-bg-card border border-surface-06">
        <div class="absolute inset-0 flex items-center justify-center gap-2 md:gap-6 px-4">
          <!-- Left stack -->
          <div class="flex flex-col items-center gap-1">
            <div class="relative w-16 md:w-20 h-8 md:h-10 rounded-lg bg-brand-gold/10 border border-brand-gold/20 flex items-center justify-center overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-0.5 bg-brand-gold/30"></div>
              <span class="text-[9px] md:text-[10px] text-text-muted">📝 日记卡</span>
            </div>
            <div class="relative w-16 md:w-20 h-8 md:h-10 rounded-lg bg-brand-gold/8 border border-brand-gold/15 flex items-center justify-center translate-x-1">
              <div class="absolute top-0 left-0 w-full h-0.5 bg-brand-gold/20"></div>
              <span class="text-[9px] md:text-[10px] text-text-muted">📍 行程卡</span>
            </div>
            <div class="relative w-16 md:w-20 h-8 md:h-10 rounded-lg bg-brand-gold/6 border border-brand-gold/10 flex items-center justify-center translate-x-2">
              <div class="absolute top-0 left-0 w-full h-0.5 bg-brand-gold/15"></div>
              <span class="text-[9px] md:text-[10px] text-text-muted">🖼 照片卡</span>
            </div>
            <span class="text-[9px] md:text-[10px] text-text-muted mt-2">记忆归档</span>
          </div>
          <!-- Middle - processing -->
          <div class="flex flex-col items-center">
            <div class="text-[28px] md:text-[40px] animate-bounce" style="animation-duration:2s">📥</div>
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl bg-brand-gold/15 border-2 border-brand-gold/25 flex items-center justify-center mt-1">
              <img src="/papafeiji.png" alt="" width="28" height="28" class="w-7 h-7 md:w-8 md:h-8 rounded-lg" />
            </div>
            <span class="text-[9px] md:text-[10px] text-brand-gold mt-1.5 font-medium">MCP 处理</span>
            <div class="text-[28px] md:text-[40px] animate-bounce mt-1" style="animation-duration:2s;animation-delay:0.5s">📤</div>
          </div>
          <!-- Right - AI readers -->
          <div class="flex flex-col items-center gap-1.5">
            <div class="w-12 h-8 md:w-14 md:h-10 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 text-[10px] md:text-xs font-medium">Cursor</div>
            <div class="w-12 h-8 md:w-14 md:h-10 rounded-lg bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-400 text-[10px] md:text-xs font-medium">Claude</div>
            <div class="w-12 h-8 md:w-14 md:h-10 rounded-lg bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 text-[10px] md:text-xs font-medium">DeepSeek</div>
            <div class="w-12 h-8 md:w-14 md:h-10 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-[10px] md:text-xs font-medium">OpenAI</div>
            <span class="text-[9px] md:text-[10px] text-text-muted mt-1">AI 读取</span>
          </div>
        </div>
      </div>
    </div>

    <!-- D: DATA PIPELINE - system architecture style -->
    <div class="mb-12">
      <p class="text-sm text-brand-gold font-medium mb-4 text-center">D. 多通道数据流</p>
      <div class="relative h-56 md:h-72 overflow-hidden rounded-3xl bg-bg-card border border-surface-06">
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 720 280" preserveAspectRatio="none">
          <defs>
            <linearGradient id="pipe-in" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="rgba(181,141,94,0.05)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/></linearGradient>
            <linearGradient id="pipe-pu" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(168,85,247,0.5)"/></linearGradient>
            <linearGradient id="pipe-or" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(249,115,22,0.5)"/></linearGradient>
            <linearGradient id="pipe-cy" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(6,182,212,0.5)"/></linearGradient>
            <linearGradient id="pipe-em" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(16,185,129,0.5)"/></linearGradient>
          </defs>
          <!-- Pipeline tracks -->
          <g opacity="0.3">
            <rect x="10" y="100" width="155" height="14" rx="7" fill="none" stroke="rgba(181,141,94,0.3)" stroke-width="1.5"/>
            <rect x="10" y="130" width="155" height="14" rx="7" fill="none" stroke="rgba(181,141,94,0.2)" stroke-width="1"/>
            <rect x="10" y="160" width="155" height="14" rx="7" fill="none" stroke="rgba(181,141,94,0.2)" stroke-width="1"/>
            <rect x="375" y="65"  width="330" height="12" rx="6" fill="none" stroke="#8B5CF6" stroke-width="1.5" opacity="0.4"/>
            <rect x="375" y="108" width="330" height="12" rx="6" fill="none" stroke="#D97706" stroke-width="1.5" opacity="0.4"/>
            <rect x="375" y="151" width="330" height="12" rx="6" fill="none" stroke="#06B6D4" stroke-width="1.5" opacity="0.4"/>
            <rect x="375" y="194" width="330" height="12" rx="6" fill="none" stroke="#10B981" stroke-width="1.5" opacity="0.4"/>
          </g>
          <!-- Flowing dots in pipes -->
          <circle cx="30" cy="107" r="3" fill="#B58D5E" opacity="0.6"><animate attributeName="cx" from="20" to="160" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="60" cy="137" r="2.5" fill="#B58D5E" opacity="0.5"><animate attributeName="cx" from="50" to="160" dur="3.5s" repeatCount="indefinite"/></circle>
          <circle cx="90" cy="167" r="2.5" fill="#B58D5E" opacity="0.5"><animate attributeName="cx" from="70" to="160" dur="4s" repeatCount="indefinite"/></circle>
          <circle cx="380" cy="71" r="3" fill="#8B5CF6" opacity="0.7"><animate attributeName="cx" from="380" to="700" dur="2.5s" repeatCount="indefinite"/></circle>
          <circle cx="390" cy="114" r="3" fill="#D97706" opacity="0.7"><animate attributeName="cx" from="390" to="700" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="385" cy="157" r="3" fill="#06B6D4" opacity="0.7"><animate attributeName="cx" from="385" to="700" dur="2.8s" repeatCount="indefinite"/></circle>
          <circle cx="395" cy="200" r="3" fill="#10B981" opacity="0.7"><animate attributeName="cx" from="395" to="700" dur="3.2s" repeatCount="indefinite"/></circle>
        </svg>
        <!-- Hub node -->
        <div class="absolute z-20" style="left:50%;top:50%;transform:translate(-50%,-50%)">
          <div class="relative w-12 h-12 md:w-16 md:h-16 rounded-xl bg-brand-gold/15 border-2 border-brand-gold/30 flex items-center justify-center shadow-lg shadow-brand-gold/20">
            <img src="/papafeiji.png" alt="" width="28" height="28" class="w-7 h-7 md:w-9 md:h-9 rounded-lg" />
          </div>
          <span class="text-[9px] text-brand-gold mt-1 block text-center">中枢</span>
        </div>
        <!-- Labels -->
        <div class="absolute" style="left:8px;top:46%"><span class="text-[9px] text-text-muted">输入</span></div>
        <div class="absolute" style="right:6%;top:20%"><span class="text-[10px] text-purple-400/70">Cursor</span></div>
        <div class="absolute" style="right:6%;top:35%"><span class="text-[10px] text-orange-400/70">Claude</span></div>
        <div class="absolute" style="right:6%;top:50%"><span class="text-[10px] text-cyan-400/70">DeepSeek</span></div>
        <div class="absolute" style="right:6%;top:66%"><span class="text-[10px] text-emerald-400/70">OpenAI</span></div>
      </div>
    </div>

    <!-- E: MOLECULAR - pure physics/aesthetic -->
    <div class="mb-12">
      <p class="text-sm text-brand-gold font-medium mb-4 text-center">E. 分子轨道模型</p>
      <div class="relative h-56 md:h-72 overflow-hidden rounded-3xl bg-bg-card border border-surface-06" style="background:radial-gradient(ellipse at 50% 50%,rgba(181,141,94,0.04) 0%,transparent 60%)">
        <div class="absolute inset-0 flex items-center justify-center">
          <!-- Nucleus -->
          <div class="absolute z-30" style="left:50%;top:50%;transform:translate(-50%,-50%)">
            <div class="w-14 h-14 rounded-full bg-brand-gold/15 border-2 border-brand-gold/30 flex items-center justify-center shadow-lg shadow-brand-gold/20">
              <img src="/papafeiji.png" alt="" width="30" height="30" class="w-7 h-7 rounded-full" />
            </div>
          </div>
          <!-- Orbit 1: tilted ellipse, purple -->
          <div class="absolute border border-purple-500/15 rounded-full" style="width:180px;height:120px;left:50%;top:50%;transform:translate(-50%,-50%) rotate(-25deg)">
            <!-- electron -->
            <div class="absolute w-9 h-9 rounded-full bg-purple-500/20 border-2 border-purple-500/30 flex items-center justify-center text-purple-400 text-[9px] font-bold" style="left:85px;top:-5px;animation:orbit1 4s linear infinite">
              Cu
            </div>
          </div>
          <!-- Orbit 2: near-vertical oval, orange -->
          <div class="absolute border border-orange-500/12 rounded-full" style="width:140px;height:200px;left:50%;top:50%;transform:translate(-50%,-50%) rotate(15deg)">
            <div class="absolute w-9 h-9 rounded-full bg-orange-500/20 border-2 border-orange-500/30 flex items-center justify-center text-orange-400 text-[9px] font-bold" style="left:65px;top:-5px;animation:orbit2 5s linear infinite">
              Cl
            </div>
          </div>
          <!-- Orbit 3: wide oval, cyan -->
          <div class="absolute border border-cyan-500/15 rounded-full" style="width:220px;height:90px;left:50%;top:50%;transform:translate(-50%,-50%) rotate(-50deg)">
            <div class="absolute w-9 h-9 rounded-full bg-cyan-500/20 border-2 border-cyan-500/30 flex items-center justify-center text-cyan-400 text-[9px] font-bold" style="left:105px;top:-5px;animation:orbit3 3.5s linear infinite">
              D
            </div>
          </div>
          <!-- Orbit 4: outer circle, emerald -->
          <div class="absolute border border-emerald-500/12 rounded-full" style="width:250px;height:250px;left:50%;top:50%;transform:translate(-50%,-50%)">
            <div class="absolute w-9 h-9 rounded-full bg-emerald-500/20 border-2 border-emerald-500/30 flex items-center justify-center text-emerald-400 text-[9px] font-bold" style="left:120px;top:-5px;animation:orbit4 6s linear infinite">
              O
            </div>
          </div>
        </div>
        <div class="absolute" style="left:50%;bottom:6%;transform:translateX(-50%)"><span class="text-[10px] text-brand-gold/70">PathMemos</span></div>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        </div>
