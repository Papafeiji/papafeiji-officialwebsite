---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
const streams = [
  {
    label: 'A',
    name: isEn ? 'Dashed Sequence' : '虚线序列',
    left: `<svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none"><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.5)" stroke-width="3" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="1.5s" repeatCount="indefinite"/></line></svg>`,
    right: `<svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none"><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.5)" stroke-width="3" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="1.5s" repeatCount="indefinite"/></line><line x1="145" y1="20" x2="290" y2="8" stroke="rgba(168,85,247,0.4)" stroke-width="2" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="1.8s" repeatCount="indefinite"/></line><line x1="145" y1="20" x2="290" y2="16" stroke="rgba(249,115,22,0.4)" stroke-width="2" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="2s" repeatCount="indefinite"/></line><line x1="145" y1="20" x2="290" y2="24" stroke="rgba(6,182,212,0.4)" stroke-width="2" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="1.6s" repeatCount="indefinite"/></line><line x1="145" y1="20" x2="290" y2="32" stroke="rgba(16,185,129,0.4)" stroke-width="2" stroke-dasharray="8 6"><animate attributeName="stroke-dashoffset" from="0" to="-28" dur="2.2s" repeatCount="indefinite"/></line></svg>`
  },
  {
    label: 'B',
    name: isEn ? 'Gradient Pulse' : '渐变脉冲',
    left: `<svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none"><defs><linearGradient id="pg"><stop offset="0%" stop-color="rgba(181,141,94,0.1)"><animate attributeName="stop-color" values="rgba(181,141,94,0.1);rgba(181,141,94,0.8);rgba(181,141,94,0.1)" dur="2.5s" repeatCount="indefinite"/></stop><stop offset="100%" stop-color="rgba(181,141,94,0.8)"><animate attributeName="stop-color" values="rgba(181,141,94,0.8);rgba(181,141,94,0.1);rgba(181,141,94,0.8)" dur="2.5s" repeatCount="indefinite"/></stop></linearGradient></defs><line x1="0" y1="20" x2="145" y2="20" stroke="url(#pg)" stroke-width="3"/></svg>`,
    right: `<svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none"><defs><linearGradient id="rp1"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(168,85,247,0.7)"><animate attributeName="stop-color" values="rgba(168,85,247,0.3);rgba(168,85,247,0.8);rgba(168,85,247,0.3)" dur="2s" repeatCount="indefinite"/></stop></linearGradient><linearGradient id="rp2"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(249,115,22,0.7)"><animate attributeName="stop-color" values="rgba(249,115,22,0.3);rgba(249,115,22,0.8);rgba(249,115,22,0.3)" dur="2.3s" repeatCount="indefinite"/></stop></linearGradient><linearGradient id="rp3"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(6,182,212,0.7)"><animate attributeName="stop-color" values="rgba(6,182,212,0.3);rgba(6,182,212,0.8);rgba(6,182,212,0.3)" dur="1.8s" repeatCount="indefinite"/></stop></linearGradient><linearGradient id="rp4"><stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(16,185,129,0.7)"><animate attributeName="stop-color" values="rgba(16,185,129,0.3);rgba(16,185,129,0.8);rgba(16,185,129,0.3)" dur="2.5s" repeatCount="indefinite"/></stop></linearGradient></defs><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.5)" stroke-width="3"><animate attributeName="opacity" values="0.3;0.7;0.3" dur="2.5s" repeatCount="indefinite"/></line><line x1="145" y1="20" x2="290" y2="8" stroke="url(#rp1)" stroke-width="2.5"/><line x1="145" y1="20" x2="290" y2="16" stroke="url(#rp2)" stroke-width="2.5"/><line x1="145" y1="20" x2="290" y2="24" stroke="url(#rp3)" stroke-width="2.5"/><line x1="145" y1="20" x2="290" y2="32" stroke="url(#rp4)" stroke-width="2.5"/></svg>`
  },
  {
    label: 'C',
    name: isEn ? 'Neon Glow Beam' : '霓虹光柱',
    left: `<svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none"><defs><filter id="gl"><feGaussianBlur stdDeviation="2"/></filter></defs><line x1="0" y1="20" x2="145" y2="20" stroke="#B58D5E" stroke-width="6" opacity="0.15" filter="url(#gl)"><animate attributeName="opacity" values="0.1;0.3;0.1" dur="2s" repeatCount="indefinite"/></line><line x1="0" y1="20" x2="145" y2="20" stroke="#B58D5E" stroke-width="1.5" opacity="0.8"/></svg>`,
    right: `<svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none"><defs><filter id="rgl"><feGaussianBlur stdDeviation="2.5"/></filter></defs><line x1="0" y1="20" x2="145" y2="20" stroke="#B58D5E" stroke-width="6" opacity="0.15" filter="url(#rgl)"><animate attributeName="opacity" values="0.1;0.3;0.1" dur="2s" repeatCount="indefinite"/></line><line x1="0" y1="20" x2="145" y2="20" stroke="#B58D5E" stroke-width="1.5" opacity="0.8"/><line x1="145" y1="20" x2="290" y2="8" stroke="#8B5CF6" stroke-width="5" opacity="0.12" filter="url(#rgl)"/><line x1="145" y1="20" x2="290" y2="8" stroke="#8B5CF6" stroke-width="1.5" opacity="0.7"/><line x1="145" y1="20" x2="290" y2="16" stroke="#D97706" stroke-width="5" opacity="0.12" filter="url(#rgl)"/><line x1="145" y1="20" x2="290" y2="16" stroke="#D97706" stroke-width="1.5" opacity="0.7"/><line x1="145" y1="20" x2="290" y2="24" stroke="#06B6D4" stroke-width="5" opacity="0.12" filter="url(#rgl)"/><line x1="145" y1="20" x2="290" y2="24" stroke="#06B6D4" stroke-width="1.5" opacity="0.7"/><line x1="145" y1="20" x2="290" y2="32" stroke="#10B981" stroke-width="5" opacity="0.12" filter="url(#rgl)"/><line x1="145" y1="20" x2="290" y2="32" stroke="#10B981" stroke-width="1.5" opacity="0.7"/></svg>`
  },
  {
    label: 'D',
    name: isEn ? 'Particle Stream' : '粒子流动',
    left: `<svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none"><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.25)" stroke-width="1.5"/><circle r="3" fill="#B58D5E" opacity="0.9"><animateMotion dur="2s" repeatCount="indefinite" path="M0,20 Q75,14 145,20"/></circle><circle r="2.5" fill="#B58D5E" opacity="0.6"><animateMotion dur="2.5s" repeatCount="indefinite" begin="0.7s" path="M0,20 Q75,26 145,20"/></circle><circle r="2" fill="#B58D5E" opacity="0.4"><animateMotion dur="3s" repeatCount="indefinite" begin="1.4s" path="M0,20 Q75,20 145,20"/></circle></svg>`,
    right: `<svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none"><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.25)" stroke-width="1.5"/><circle r="3" fill="#B58D5E" opacity="0.9"><animateMotion dur="2s" repeatCount="indefinite" path="M0,20 Q75,14 145,20"/></circle><circle r="2.5" fill="#B58D5E" opacity="0.6"><animateMotion dur="2.5s" repeatCount="indefinite" begin="0.7s" path="M0,20 Q75,26 145,20"/></circle><line x1="145" y1="20" x2="290" y2="8" stroke="rgba(168,85,247,0.2)" stroke-width="1"/><line x1="145" y1="20" x2="290" y2="16" stroke="rgba(249,115,22,0.2)" stroke-width="1"/><line x1="145" y1="20" x2="290" y2="24" stroke="rgba(6,182,212,0.2)" stroke-width="1"/><line x1="145" y1="20" x2="290" y2="32" stroke="rgba(16,185,129,0.2)" stroke-width="1"/><circle r="3" fill="#8B5CF6" opacity="0.8"><animateMotion dur="2.8s" repeatCount="indefinite" begin="1s" path="M145,20 Q220,8 290,8"/></circle><circle r="3" fill="#D97706" opacity="0.8"><animateMotion dur="3s" repeatCount="indefinite" begin="1.5s" path="M145,20 Q220,16 290,16"/></circle><circle r="3" fill="#06B6D4" opacity="0.8"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.5s" path="M145,20 Q220,24 290,24"/></circle><circle r="3" fill="#10B981" opacity="0.8"><animateMotion dur="3.2s" repeatCount="indefinite" begin="2s" path="M145,20 Q220,32 290,32"/></circle></svg>`
  },
  {
    label: 'E',
    name: isEn ? 'Double Orbit' : '双轨交替',
    left: `<svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none"><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.2)" stroke-width="1.5"/><path d="M0,18 Q75,10 145,18" fill="none" stroke="#B58D5E" stroke-width="2" opacity="0.7"><animate attributeName="opacity" values="0.3;0.8;0.3" dur="2s" repeatCount="indefinite"/></path><path d="M0,22 Q75,30 145,22" fill="none" stroke="#B58D5E" stroke-width="2" opacity="0.7"><animate attributeName="opacity" values="0.8;0.3;0.8" dur="2s" repeatCount="indefinite"/></path></svg>`,
    right: `<svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none"><line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.2)" stroke-width="1.5"/><path d="M0,18 Q75,10 145,18" fill="none" stroke="#B58D5E" stroke-width="2" opacity="0.7"><animate attributeName="opacity" values="0.3;0.8;0.3" dur="2s" repeatCount="indefinite"/></path><path d="M0,22 Q75,30 145,22" fill="none" stroke="#B58D5E" stroke-width="2" opacity="0.7"><animate attributeName="opacity" values="0.8;0.3;0.8" dur="2s" repeatCount="indefinite"/></path><line x1="145" y1="20" x2="290" y2="8" stroke="rgba(168,85,247,0.25)" stroke-width="1.5"/><line x1="145" y1="20" x2="290" y2="16" stroke="rgba(249,115,22,0.25)" stroke-width="1.5"/><line x1="145" y1="20" x2="290" y2="24" stroke="rgba(6,182,212,0.25)" stroke-width="1.5"/><line x1="145" y1="20" x2="290" y2="32" stroke="rgba(16,185,129,0.25)" stroke-width="1.5"/><circle r="4" fill="#8B5CF6" opacity="0.6"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2s" repeatCount="indefinite"/></circle><circle r="4" fill="#D97706" opacity="0.6" cx="180" cy="16"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2.3s" repeatCount="indefinite"/></circle><circle r="4" fill="#06B6D4" opacity="0.6" cx="220" cy="24"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="1.8s" repeatCount="indefinite"/></circle><circle r="4" fill="#10B981" opacity="0.6" cx="260" cy="32"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="2.5s" repeatCount="indefinite"/></circle></svg>`
  }
];
---

<section id="mcp" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('mcp.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('mcp.title.1')}<span class="gradient-text">{_('mcp.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('mcp.subtitle')}</p>
    </div>

    <!-- 5 stream variants for comparison -->
    <div class="space-y-6 mb-20">
      {streams.map(s => (
        <div class="overflow-hidden rounded-3xl bg-bg-card border border-surface-06 px-4 md:px-8 py-6 md:py-8">
          <div class="text-center mb-4">
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-surface-04 border border-surface-06 text-sm text-brand-gold font-medium">{s.label}. {s.name}</span>
          </div>
          <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6">
            <!-- Left: Memory Source (compact) -->
            <div class="flex flex-col items-center gap-2 shrink-0">
              <div class="flex gap-2">
                <div class="px-3 py-1.5 rounded-lg bg-brand-gold/8 border border-brand-gold/15 text-xs text-text-primary font-medium">生活记忆</div>
                <div class="px-3 py-1.5 rounded-lg bg-blue-500/8 border border-blue-500/15 text-xs text-text-primary font-medium">工作记忆</div>
              </div>
            </div>
            <!-- Stream left -->
            <div class="hidden md:flex flex-1 items-center h-8" set:html={s.left} />
            <div class="flex md:hidden text-brand-gold text-lg animate-bounce">→</div>
            <!-- Hub (compact) -->
            <div class="flex items-center gap-2 shrink-0">
              <img src="/papafeiji.png" alt="PathMemos" width="36" height="36" class="w-9 h-9 rounded-lg shadow-sm shadow-brand-gold/20" />
              <span class="text-xs text-brand-gold font-medium">PathMemos</span>
            </div>
            <!-- Stream right -->
            <div class="hidden md:flex flex-1 items-center h-8" set:html={s.right} />
            <div class="flex md:hidden text-brand-gold text-lg animate-bounce">→</div>
            <!-- Right: AI tools (compact) -->
            <div class="flex gap-2 shrink-0">
              <div class="w-8 h-8 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 text-[10px] font-bold">Cu</div>
              <div class="w-8 h-8 rounded-lg bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-400 text-[10px] font-bold">Cl</div>
              <div class="w-8 h-8 rounded-lg bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 text-[10px] font-bold">D</div>
              <div class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-[10px] font-bold">O</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Write · Smart Archiving' : '记忆写入 · 智能沉淀'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'AI auto-summarizes conversations, extracts key insights, and batch-archives them as personal memories. Supports local draft caching and offline retry.' : 'AI 可自动总结对话、提炼关键信息，批量归档为个人记忆。支持本地草稿缓存、断网续传，保证记忆不丢失。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Read · Full Recall' : '记忆读取 · 全域召回'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Batch retrieve all diaries, trajectories, and archived memories by time range. Let AI understand your habits, past experiences, and personal preferences.' : '支持按时间范围批量检索全部日记、轨迹与存档记忆，让 AI 理解你的生活习惯、过往经历与个人偏好。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Secure & Controllable' : '安全可控机制'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Self-manage API keys with rotation support, rate limiting, and caching. Private and cloud data are fully isolated.' : '自主管理 API 密钥，支持随时轮换、限流保护、缓存加速，私有化数据与云端数据完全隔离，绝对私密安全。'}
        </p>
      </div>
    </div>
  </div>
</section>
