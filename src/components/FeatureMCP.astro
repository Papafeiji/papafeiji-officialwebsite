---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---
<section id="mcp" class="relative py-20 md:py-32 px-6 overflow-hidden" data-reveal>
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('mcp.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('mcp.title.1')}<span class="gradient-text">{_('mcp.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('mcp.subtitle')}</p>
    </div>

    <div class="relative mb-20 overflow-hidden rounded-3xl bg-bg-card border border-surface-06 px-4 md:px-10 py-10 md:py-14">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-10">

        <!-- Left: Memory Source -->
        <div class="flex flex-col items-center gap-3 shrink-0">
          <span class="text-sm md:text-base text-text-primary font-semibold">{isEn ? 'Your Memories' : '你的记忆'}</span>
          <div class="flex flex-col gap-2">
            <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-brand-gold/8 border border-brand-gold/15 hover:bg-brand-gold/12 transition-colors">
              <div class="w-9 h-9 rounded-lg bg-brand-gold/15 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <div class="text-sm text-text-primary font-medium">{isEn ? 'Life' : '生活记忆'}</div>
                <div class="text-[10px] md:text-xs text-text-muted">{isEn ? 'Family, travel, daily life' : '家庭、出行、日常'}</div>
              </div>
            </div>
            <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-blue-500/8 border border-blue-500/15 hover:bg-blue-500/12 transition-colors">
              <div class="w-9 h-9 rounded-lg bg-blue-500/15 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.5"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              </div>
              <div>
                <div class="text-sm text-text-primary font-medium">{isEn ? 'Work' : '工作记忆'}</div>
                <div class="text-[10px] md:text-xs text-text-muted">{isEn ? 'Projects, consultations, notes' : '项目、咨询、笔记'}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Stream: Memory → Hub -->
        <div class="hidden md:flex flex-1 items-center h-10">
          <svg class="w-full h-full" viewBox="0 0 150 40" preserveAspectRatio="none">
            <line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.25)" stroke-width="1.5"/>
            <circle r="3" fill="#B58D5E" opacity="0.9"><animateMotion dur="2s" repeatCount="indefinite" path="M0,20 Q75,14 145,20"/></circle>
            <circle r="2.5" fill="#B58D5E" opacity="0.6"><animateMotion dur="2.5s" repeatCount="indefinite" begin="0.7s" path="M0,20 Q75,26 145,20"/></circle>
            <circle r="2" fill="#B58D5E" opacity="0.4"><animateMotion dur="3s" repeatCount="indefinite" begin="1.4s" path="M0,20 Q75,20 145,20"/></circle>
          </svg>
        </div>
        <div class="flex md:hidden text-2xl text-brand-gold animate-bounce">→</div>

        <!-- Center: PathMemos Hub -->
        <div class="flex flex-col items-center gap-2 shrink-0">
          <div class="relative">
            <img src="/newlogo-128.webp" srcset="/newlogo-128.webp 1x, /newlogo-256.webp 2x" alt="PathMemos" width="72" height="72" class="w-[72px] h-[72px] md:w-[96px] md:h-[96px] rounded-2xl shadow-lg shadow-brand-gold/30" loading="lazy" decoding="async" />
            <div class="absolute -inset-3 rounded-3xl bg-brand-gold/10 animate-ping" style="animation-duration:2.5s"></div>
          </div>
          <span class="text-sm md:text-base text-brand-gold font-semibold">PathMemos</span>
          <span class="text-[10px] md:text-xs text-text-muted">{isEn ? 'MCP Memory Hub' : 'MCP 记忆中枢'}</span>
        </div>

        <!-- Stream: Hub → AI Tools -->
        <div class="hidden md:flex flex-1 items-center h-10">
          <svg class="w-full h-full" viewBox="0 0 300 40" preserveAspectRatio="none">
            <line x1="0" y1="20" x2="145" y2="20" stroke="rgba(181,141,94,0.25)" stroke-width="1.5"/>
            <circle r="3" fill="#B58D5E" opacity="0.9"><animateMotion dur="2s" repeatCount="indefinite" path="M0,20 Q75,14 145,20"/></circle>
            <circle r="2.5" fill="#B58D5E" opacity="0.6"><animateMotion dur="2.5s" repeatCount="indefinite" begin="0.7s" path="M0,20 Q75,26 145,20"/></circle>
            <line x1="145" y1="20" x2="290" y2="8"  stroke="rgba(168,85,247,0.2)" stroke-width="1"/>
            <line x1="145" y1="20" x2="290" y2="16" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
            <line x1="145" y1="20" x2="290" y2="24" stroke="rgba(6,182,212,0.2)" stroke-width="1"/>
            <line x1="145" y1="20" x2="290" y2="32" stroke="rgba(16,185,129,0.2)" stroke-width="1"/>
            <circle r="3" fill="#8B5CF6" opacity="0.8"><animateMotion dur="2.8s" repeatCount="indefinite" begin="1s" path="M145,20 Q220,8 290,8"/></circle>
            <circle r="3" fill="#D97706" opacity="0.8"><animateMotion dur="3s" repeatCount="indefinite" begin="1.5s" path="M145,20 Q220,16 290,16"/></circle>
            <circle r="3" fill="#06B6D4" opacity="0.8"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.5s" path="M145,20 Q220,24 290,24"/></circle>
            <circle r="3" fill="#10B981" opacity="0.8"><animateMotion dur="3.2s" repeatCount="indefinite" begin="2s" path="M145,20 Q220,32 290,32"/></circle>
          </svg>
        </div>
        <div class="flex md:hidden text-2xl text-brand-gold animate-bounce">→</div>

        <!-- Right: AI Tools -->
        <div class="flex flex-col gap-3 shrink-0">
          <div class="flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center p-0.5 transition-all group-hover:scale-110">
              <img src="/openclaw.svg" alt="OpenClaw" width="36" height="36" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
            <span class="text-sm text-text-primary font-medium">OpenClaw</span>
          </div>
          <div class="flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center p-0.5 transition-all group-hover:scale-110">
              <img src="/chatgpt.svg" alt="ChatGPT" width="36" height="36" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
            <span class="text-sm text-text-primary font-medium">ChatGPT</span>
          </div>
          <div class="flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center p-0.5 transition-all group-hover:scale-110">
              <img src="/claude.svg" alt="Claude" width="36" height="36" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
            <span class="text-sm text-text-primary font-medium">Claude</span>
          </div>
          <div class="flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center p-0.5 transition-all group-hover:scale-110">
              <img src="/kimi.svg" alt="Kimi" width="36" height="36" class="w-full h-full object-contain" loading="lazy" decoding="async" />
            </div>
            <span class="text-sm text-text-primary font-medium">Kimi</span>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <p class="text-xs text-text-muted">
          {isEn ? 'Standard MCP protocol endpoint — one memory source, all AIs can access: OpenClaw, ChatGPT, Claude, Kimi, and more.' : '标准 MCP 协议端点 — 一处记忆，全部 AI 共享读取：OpenClaw、ChatGPT、Claude、Kimi 等。'}
        </p>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Write · Smart Archiving' : '记忆写入 · 智能沉淀'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'AI auto-summarizes conversations, extracts key insights, and batch-archives them as personal memories. Supports local draft caching and offline retry.' : 'AI 可自动总结对话、提炼关键信息，批量归档为个人记忆。支持本地草稿缓存、断网续传，保证记忆不丢失。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Read · Full Recall' : '记忆读取 · 全域召回'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Batch retrieve all diaries, trajectories, and archived memories by time range. Let AI understand your habits, past experiences, and personal preferences.' : '支持按时间范围批量检索全部日记、轨迹与存档记忆，让 AI 理解你的生活习惯、过往经历与个人偏好。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06 hover:border-brand-gold/30 hover:bg-surface-02 transition-all duration-300">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Secure & Controllable' : '安全可控机制'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Self-manage API keys with rotation support, rate limiting, and caching. Private and cloud data are fully isolated.' : '自主管理 API 密钥，支持随时轮换、限流保护、缓存加速，私有化数据与云端数据完全隔离，绝对私密安全。'}
        </p>
      </div>
    </div>
  </div>
</section>
