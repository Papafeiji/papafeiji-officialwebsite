---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
const isEn = lang === 'en';
---

<style>
  @keyframes flowDot1 { 0%,100%{opacity:0.2;transform:scale(0.8)} 20%{opacity:1;transform:scale(1.2)} 40%{opacity:0.4;transform:scale(0.9)} }
  @keyframes flowDot2 { 0%,100%{opacity:0.3;transform:scale(0.8)} 30%{opacity:1;transform:scale(1.2)} 50%{opacity:0.4;transform:scale(0.9)} }
  @keyframes flowDot3 { 0%,100%{opacity:0.2;transform:scale(0.8)} 15%{opacity:1;transform:scale(1.2)} 35%{opacity:0.4;transform:scale(0.9)} }
  @keyframes flowDot4 { 0%,100%{opacity:0.3;transform:scale(0.8)} 25%{opacity:1;transform:scale(1.2)} 45%{opacity:0.4;transform:scale(0.9)} }
  @keyframes dataPulse { 0%,100%{opacity:0;transform:translateY(0)} 50%{opacity:1;transform:translateY(-4px)} }
  @keyframes hubPulse { 0%,100%{transform:translate(-50%,-50%) scale(1);opacity:0.6} 50%{transform:translate(-50%,-50%) scale(1.3);opacity:0} }
  @keyframes nodeGlow { 0%,100%{opacity:0.5} 50%{opacity:1} }
</style>

<section id="mcp" class="relative py-20 md:py-32 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('mcp.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('mcp.title.1')}<span class="gradient-text">{_('mcp.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">{_('mcp.subtitle')}</p>
    </div>

    <!-- Data flow illustration -->
    <div class="relative mb-20 h-60 md:h-80 overflow-hidden rounded-3xl bg-bg-card border border-surface-06">

      <!-- Left: Data sources cluster -->
      <div class="absolute z-10" style="left:5%;top:50%;transform:translateY(-50%)">
        <div class="flex flex-col items-center gap-3">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-brand-gold/10 border border-brand-gold/20 flex items-center justify-center" style="animation:dataPulse 3s ease-in-out infinite">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
          </div>
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-brand-gold/10 border border-brand-gold/20 flex items-center justify-center" style="animation:dataPulse 3s ease-in-out infinite 0.6s">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-brand-gold/10 border border-brand-gold/20 flex items-center justify-center" style="animation:dataPulse 3s ease-in-out infinite 1.2s">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B58D5E" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </div>
          <span class="text-[10px] md:text-xs text-text-muted">{isEn ? 'Memories' : '记忆数据'}</span>
        </div>
      </div>

      <!-- Center: PathMemos Hub -->
      <div class="absolute z-20 flex flex-col items-center" style="left:50%;top:50%;transform:translate(-50%,-50%)">
        <div class="relative">
          <div class="w-16 h-16 md:w-24 md:h-24 rounded-2xl bg-brand-gold/15 border-2 border-brand-gold/30 flex items-center justify-center shadow-lg shadow-brand-gold/20">
            <img src="/papafeiji.png" alt="" width="48" height="48" class="w-10 h-10 md:w-14 md:h-14 rounded-xl" />
          </div>
          <!-- Pulse rings -->
          <div class="absolute w-16 h-16 md:w-24 md:h-24 rounded-2xl bg-brand-gold/15 border border-brand-gold/30" style="left:50%;top:50%;transform:translate(-50%,-50%);animation:hubPulse 2.5s ease-out infinite"></div>
          <div class="absolute w-16 h-16 md:w-24 md:h-24 rounded-2xl bg-brand-gold/15 border border-brand-gold/30" style="left:50%;top:50%;transform:translate(-50%,-50%);animation:hubPulse 2.5s ease-out infinite 0.8s"></div>
        </div>
        <span class="text-xs md:text-sm text-brand-gold mt-3 font-semibold">PathMemos</span>
        <span class="text-[10px] md:text-xs text-text-muted mt-0.5">{isEn ? 'Memory Hub' : '记忆中枢'}</span>
      </div>

      <!-- Right: AI Tools -->
      <svg class="absolute inset-0 w-full h-full z-0" viewBox="0 0 720 300" preserveAspectRatio="none">
        <defs>
          <linearGradient id="flow-to-hub" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(181,141,94,0.05)"/><stop offset="100%" stop-color="rgba(181,141,94,0.3)"/>
          </linearGradient>
          <linearGradient id="flow-to-ai1" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(168,85,247,0.4)"/>
          </linearGradient>
          <linearGradient id="flow-to-ai2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(249,115,22,0.4)"/>
          </linearGradient>
          <linearGradient id="flow-to-ai3" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(6,182,212,0.4)"/>
          </linearGradient>
          <linearGradient id="flow-to-ai4" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(181,141,94,0.3)"/><stop offset="100%" stop-color="rgba(16,185,129,0.4)"/>
          </linearGradient>
        </defs>

        <!-- Left: Data sources → Hub (inbound flow lines) -->
        <g opacity="0.5">
          <line x1="40" y1="115" x2="310" y2="150" stroke="url(#flow-to-hub)" stroke-width="2" stroke-dasharray="6 3"/>
          <line x1="40" y1="150" x2="310" y2="150" stroke="url(#flow-to-hub)" stroke-width="2" stroke-dasharray="6 3"/>
          <line x1="40" y1="185" x2="310" y2="150" stroke="url(#flow-to-hub)" stroke-width="2" stroke-dasharray="6 3"/>
        </g>

        <!-- Hub → AI tools (outbound flow lines) -->
        <g opacity="0.6">
          <line x1="410" y1="105" x2="680" y2="60"  stroke="url(#flow-to-ai1)" stroke-width="2" stroke-dasharray="6 3"/>
          <line x1="410" y1="140" x2="680" y2="120" stroke="url(#flow-to-ai2)" stroke-width="2" stroke-dasharray="6 3"/>
          <line x1="410" y1="175" x2="680" y2="180" stroke="url(#flow-to-ai3)" stroke-width="2" stroke-dasharray="6 3"/>
          <line x1="410" y1="210" x2="680" y2="240" stroke="url(#flow-to-ai4)" stroke-width="2" stroke-dasharray="6 3"/>
        </g>
      </svg>

      <!-- Flowing data dots on paths -->
      <div class="absolute w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-brand-gold/80 shadow-sm shadow-brand-gold/50 z-10"
           style="left:12%;top:47%;animation:flowDot1 3s linear infinite"></div>
      <div class="absolute w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-purple-400/80 shadow-sm shadow-purple-400/50 z-10"
           style="left:62%;top:33%;animation:flowDot2 3s linear infinite"></div>
      <div class="absolute w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-orange-400/80 shadow-sm shadow-orange-400/50 z-10"
           style="left:62%;top:44%;animation:flowDot3 3.5s linear infinite"></div>
      <div class="absolute w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-cyan-400/80 shadow-sm shadow-cyan-400/50 z-10"
           style="left:62%;top:56%;animation:flowDot4 3s linear infinite"></div>

      <!-- Right: AI tool nodes -->
      <div class="absolute z-10 flex items-center gap-2" style="right:6%;top:14%">
        <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-purple-500/15 border border-purple-500/25 flex items-center justify-center shadow-lg" style="animation:nodeGlow 2.5s ease-in-out infinite">
          <span class="text-purple-400 text-xs md:text-sm font-bold">Cu</span>
        </div>
        <span class="text-[10px] md:text-xs text-text-muted">Cursor</span>
      </div>
      <div class="absolute z-10 flex items-center gap-2" style="right:6%;top:34%">
        <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-orange-500/15 border border-orange-500/25 flex items-center justify-center shadow-lg" style="animation:nodeGlow 3s ease-in-out infinite 0.5s">
          <span class="text-orange-400 text-xs md:text-sm font-bold">Cl</span>
        </div>
        <span class="text-[10px] md:text-xs text-text-muted">Claude</span>
      </div>
      <div class="absolute z-10 flex items-center gap-2" style="right:6%;top:54%">
        <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-cyan-500/15 border border-cyan-500/25 flex items-center justify-center shadow-lg" style="animation:nodeGlow 3.5s ease-in-out infinite 1s">
          <span class="text-cyan-400 text-xs md:text-sm font-bold">D</span>
        </div>
        <span class="text-[10px] md:text-xs text-text-muted">DeepSeek</span>
      </div>
      <div class="absolute z-10 flex items-center gap-2" style="right:6%;top:74%">
        <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center shadow-lg" style="animation:nodeGlow 4s ease-in-out infinite 1.5s">
          <span class="text-emerald-400 text-xs md:text-sm font-bold">O</span>
        </div>
        <span class="text-[10px] md:text-xs text-text-muted">OpenAI</span>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Write · Smart Archiving' : '记忆写入 · 智能沉淀'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'AI auto-summarizes conversations, extracts key insights, and batch-archives them as personal memories. Supports local draft caching and offline retry — your memories are never lost.' : 'AI 可自动总结对话、提炼关键信息，批量归档为个人记忆。支持本地草稿缓存、断网续传，保证记忆不丢失。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Memory Read · Full Recall' : '记忆读取 · 全域召回'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Batch retrieve all diaries, trajectories, and archived memories by time range. Let AI understand your habits, past experiences, and personal preferences.' : '支持按时间范围批量检索全部日记、轨迹与存档记忆，让 AI 理解你的生活习惯、过往经历与个人偏好。'}
        </p>
      </div>
      <div class="p-8 rounded-2xl bg-bg-card border border-surface-06">
        <div class="w-12 h-12 rounded-xl bg-brand-gold/10 flex items-center justify-center text-brand-gold mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-4">{isEn ? 'Secure & Controllable' : '安全可控机制'}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          {isEn ? 'Self-manage API keys with rotation support, rate limiting, and caching. Private and cloud data are fully isolated — absolutely private and secure.' : '自主管理 API 密钥，支持随时轮换、限流保护、缓存加速，私有化数据与云端数据完全隔离，绝对私密安全。'}
        </p>
      </div>
    </div>
  </div>
</section>
