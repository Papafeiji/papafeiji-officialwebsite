---
import ScrollReveal from './ScrollReveal.tsx';
---

<section id="open-source" class="relative py-32 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_50%,rgba(181,141,94,0.1),transparent)]"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <ScrollReveal client:visible>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/[0.03] border border-white/[0.06] mb-10">
        <span class="text-sm text-brand-gold font-medium">开源生态</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        完全开源，<span class="gradient-text">自由定制</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-12">
        采用标准开源协议，代码完全透明。你可以私有化部署、二次开发、甚至商业使用。
      </p>
    </ScrollReveal>

    <ScrollReveal client:visible delay={200}>
      <div class="code-block text-left mb-10">
        <div class="code-header">
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="ml-2 text-xs text-text-muted">一键安装</span>
        </div>
        <div class="code-body">
          <div><span class="prompt">$</span> <span class="cmd">curl -fsSL https://papafeiji.cn/install.sh | bash</span></div>
          <div class="text-text-muted mt-2"># 按提示选择 opensource 模式 + SQLite 数据库，5 分钟完成部署</div>
        </div>
      </div>
    </ScrollReveal>

    <ScrollReveal client:visible delay={300}>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://github.com/papafeiji/papafeiji-saas" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white text-[#0a0a0f] font-semibold hover:bg-gray-100 transition-colors">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          访问 GitHub 仓库
        </a>
        <a href="/tutorial" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white/[0.04] border border-white/[0.08] text-text-primary font-semibold hover:bg-white/[0.08] transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          阅读文档
        </a>
      </div>
    </ScrollReveal>

    <ScrollReveal client:visible delay={400}>
      <div class="mt-16 grid md:grid-cols-3 gap-6 text-left">
        <div class="p-6 rounded-xl bg-white/[0.02] border border-white/[0.06]">
          <div class="text-3xl font-bold text-brand-gold mb-2">双模式</div>
          <p class="text-sm text-text-secondary">SaaS 商业运营 + 开源私有化部署，同一套代码满足不同场景</p>
        </div>
        <div class="p-6 rounded-xl bg-white/[0.02] border border-white/[0.06]">
          <div class="text-3xl font-bold text-brand-gold mb-2">双数据库</div>
          <p class="text-sm text-text-secondary">SQLite 零运维快速启动，PostgreSQL 生产级高并发支持</p>
        </div>
        <div class="p-6 rounded-xl bg-white/[0.02] border border-white/[0.06]">
          <div class="text-3xl font-bold text-brand-gold mb-2">MIT 协议</div>
          <p class="text-sm text-text-secondary">标准开源协议，可自由修改、分发、商用，无后顾之忧</p>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
