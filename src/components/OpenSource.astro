---
import { createT } from '../i18n/translations';
export interface Props { lang?: string; }
const { lang = 'zh' } = Astro.props;
const _ = createT(lang);
---

<section id="open-source" class="relative py-32 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_50%,rgba(181,141,94,0.1),transparent)]"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-03 border border-surface-06 mb-10">
        <span class="text-sm text-brand-gold font-medium">{_('opensource.badge')}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">
        {_('opensource.title.1')}<span class="gradient-text">{_('opensource.title.2')}</span>
      </h2>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-12">
        {_('opensource.subtitle')}
      </p>
    

    
      <div class="code-block text-left mb-10">
        <div class="code-header">
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="ml-2 text-xs text-text-muted">{_('opensource.install')}</span>
        </div>
        <div class="code-body">
          <div><span class="prompt">$</span> <span class="cmd">curl -fsSL https://raw.githubusercontent.com/Papafeiji/pathmemos/open/scripts/install.sh | bash</span></div>
          <div class="text-text-muted mt-2">{_('how.cmd.comment')}</div>
        </div>
      </div>
    

    
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://github.com/Papafeiji/pathmemos" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-contrast-btn-bg text-contrast-btn-text font-semibold hover:opacity-90 transition-all">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          {_('opensource.ghBtn')}
        </a>
        <a href={lang === 'en' ? '/en/tutorial' : '/tutorial'} class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-surface-04 border border-surface-08 text-text-primary font-semibold hover:bg-surface-08 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          {_('opensource.docBtn')}
        </a>
      </div>
    

    
      <div class="mt-16 grid md:grid-cols-3 gap-6 text-left">
        <div class="p-6 rounded-xl bg-surface-02 border border-surface-06">
          <div class="text-3xl font-bold text-brand-gold mb-2">{_('opensource.card1.title')}</div>
          <p class="text-sm text-text-secondary">{_('opensource.card1.desc')}</p>
        </div>
        <div class="p-6 rounded-xl bg-surface-02 border border-surface-06">
          <div class="text-3xl font-bold text-brand-gold mb-2">{_('opensource.card2.title')}</div>
          <p class="text-sm text-text-secondary">{_('opensource.card2.desc')}</p>
        </div>
        <div class="p-6 rounded-xl bg-surface-02 border border-surface-06">
          <div class="text-3xl font-bold text-brand-gold mb-2">{_('opensource.card3.title')}</div>
          <p class="text-sm text-text-secondary">{_('opensource.card3.desc')}</p>
        </div>
      </div>
    
  </div>
</section>
